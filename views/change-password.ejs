<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ganti Password - SI Mitra DUDIKA</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@600;700&display=swap" rel="stylesheet">

<!-- ✅ FONT AWESOME 6 CDN -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<style>
:root {
    --uniba-primary: #1a3a5c;
    --uniba-blue-light: #2c5282;
    --uniba-gold: #d4a017;
    --success: #10b981;
    --danger: #ef4444;
    --text-dark: #1e293b;
    --text-muted: #64748b;
    --bg-light: #f8fafc;
    --border: #e2e8f0;
    --sidebar-width: 280px;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body { 
    font-family: 'Inter', sans-serif; 
    background: var(--bg-light); 
    color: var(--text-dark);
    line-height: 1.6;
    min-height: 100vh;
    overflow-x: hidden;
    background-image:
        radial-gradient(circle at 10% 20%, rgba(212, 160, 23, 0.03) 0%, transparent 40%),
        radial-gradient(circle at 90% 80%, rgba(26, 58, 92, 0.03) 0%, transparent 40%);
}

.main-wrapper { 
    margin-left: var(--sidebar-width); 
    transition: margin-left 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex; 
    justify-content: center; 
    align-items: center; 
    padding: 32px 20px; 
    min-height: 100vh; 
}
.main-wrapper.expanded { margin-left: 0; }

/* ✅ FORM CONTAINER (DIKECILKAN) */
.form-container { 
    width: 100%; 
    max-width: 480px; 
    background: white; 
    padding: 32px; 
    border-radius: 16px; 
    box-shadow: 0 10px 40px rgba(0,0,0,0.08); 
    border: 1px solid var(--border); 
}

/* ✅ FORM HEADER */
.form-header { 
    text-align: center; 
    margin-bottom: 24px; 
}

.form-header h1 { 
    font-family: 'Poppins', sans-serif; 
    color: var(--uniba-primary); 
    font-size: 1.35rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
}

.form-header h1 i {
    color: var(--uniba-gold);
    font-size: 1.2rem;
}

.form-header p { 
    color: var(--text-muted); 
    font-size: 0.82rem; 
    margin-top: 4px; 
}

.form-group { margin-bottom: 18px; }

.form-group label { 
    display: flex;
    align-items: center;
    gap: 6px;
    font-weight: 600; 
    font-size: 0.78rem; 
    margin-bottom: 6px; 
    color: var(--text-dark); 
}

.form-group label i {
    font-size: 0.75rem;
    color: var(--uniba-gold);
}

.form-group input { 
    width: 100%; 
    padding: 10px 42px 10px 14px; 
    border: 2px solid var(--border); 
    border-radius: 9px; 
    font-size: 0.88rem; 
    font-family: 'Inter', sans-serif; 
    transition: all 0.3s; 
    background: #f8fafc;
    color: var(--text-dark);
}
.form-group input:focus { 
    outline: none; 
    border-color: var(--uniba-primary); 
    background: #fff;
    box-shadow: 0 0 0 4px rgba(26, 58, 92, 0.1); 
}

/* ✅ PASSWORD WRAPPER */
.password-wrapper { 
    position: relative; 
    display: flex; 
    align-items: center; 
}

/* ✅ TOGGLE PASSWORD BUTTON (FONT AWESOME) */
.toggle-password { 
    position: absolute; 
    right: 10px; 
    top: 50%; 
    transform: translateY(-50%); 
    cursor: pointer; 
    color: var(--text-muted); 
    background: none; 
    border: none; 
    padding: 6px;
    border-radius: 6px;
    display: flex; 
    align-items: center;
    justify-content: center;
    transition: all 0.3s;
}

.toggle-password:hover { 
    color: var(--uniba-primary);
    background: rgba(26, 58, 92, 0.06);
}

.toggle-password i {
    font-size: 0.9rem;
    pointer-events: none;
}

.toggle-password .icon-eye-off { display: none; }
.toggle-password.is-visible .icon-eye { display: none; }
.toggle-password.is-visible .icon-eye-off { display: inline; }

/* ✅ BUTTON */
.btn { 
    width: 100%; 
    padding: 12px; 
    border-radius: 9px; 
    font-weight: 600; 
    font-size: 0.88rem; 
    cursor: pointer; 
    border: none; 
    transition: all 0.3s; 
    font-family: 'Inter', sans-serif; 
    display: flex; 
    justify-content: center; 
    align-items: center; 
    gap: 8px; 
}

.btn i {
    font-size: 0.85rem;
    transition: transform 0.3s ease;
}

.btn-primary { 
    background: linear-gradient(135deg, var(--uniba-primary), var(--uniba-blue-light)); 
    color: white; 
    box-shadow: 0 4px 12px rgba(26, 58, 92, 0.2); 
}
.btn-primary:hover { 
    transform: translateY(-2px); 
    box-shadow: 0 6px 20px rgba(26, 58, 92, 0.35); 
}
.btn-primary:hover i {
    transform: scale(1.15);
}

/* ✅ ALERT (DIKECILKAN) */
.alert { 
    padding: 12px 16px; 
    border-radius: 9px; 
    margin-bottom: 20px; 
    font-size: 0.82rem; 
    font-weight: 500; 
    display: flex; 
    align-items: center; 
    gap: 10px; 
}

.alert i {
    font-size: 1rem;
    flex-shrink: 0;
}

.alert-error { 
    background: #fef2f2; 
    color: #991b1b; 
    border: 1px solid #fecaca; 
}
.alert-error i { color: var(--danger); }

.alert-success { 
    background: #f0fdf4; 
    color: #166534; 
    border: 1px solid #bbf7d0; 
}
.alert-success i { color: var(--success); }

/* ✅ INFO BOX (DIKECILKAN) */
.info-box { 
    margin-top: 20px; 
    padding: 12px 16px; 
    background: #f8fafc; 
    border-radius: 9px; 
    font-size: 0.78rem; 
    color: var(--text-muted); 
    border-left: 4px solid var(--uniba-primary); 
    display: flex;
    align-items: flex-start;
    gap: 8px;
}

.info-box i {
    color: var(--uniba-gold);
    font-size: 0.9rem;
    margin-top: 2px;
    flex-shrink: 0;
}

.info-box strong { color: var(--uniba-primary); }

@media (max-width: 768px) {
    .main-wrapper { 
        margin-left: 0; 
        padding: 70px 15px 30px; 
    }
    .main-wrapper.expanded { margin-left: 0; }
    .form-container { padding: 24px 18px; }
    .form-header h1 { font-size: 1.2rem; }
    .form-header p { font-size: 0.78rem; }
}
</style>

</head>
<body>
<%- include('partials/_sidebar') %>

<div class="main-wrapper">
    <div class="form-container">
        <div class="form-header">
            <h1>
                <i class="fa-solid fa-key"></i>
                Ganti Password
            </h1>
            <p>Amankan akun SI Mitra DUDIKA Anda</p>
        </div>

        <% if (error) { %>
            <div class="alert alert-error">
                <i class="fa-solid fa-triangle-exclamation"></i>
                <span><%= error %></span>
            </div>
        <% } %>
        <% if (success) { %>
            <div class="alert alert-success">
                <i class="fa-solid fa-circle-check"></i>
                <span><%= success %></span>
            </div>
        <% } %>

        <form method="POST" action="/change-password">
            <!-- Password Lama -->
            <div class="form-group">
                <label>
                    <i class="fa-solid fa-lock"></i>
                    Password Lama
                </label>
                <div class="password-wrapper">
                    <input type="password" name="old_password" required placeholder="Masukkan password saat ini">
                    <button type="button" class="toggle-password" aria-label="Tampilkan password">
                        <i class="fa-solid fa-eye icon-eye"></i>
                        <i class="fa-solid fa-eye-slash icon-eye-off"></i>
                    </button>
                </div>
            </div>
            
            <!-- Password Baru -->
            <div class="form-group">
                <label>
                    <i class="fa-solid fa-shield-halved"></i>
                    Password Baru
                </label>
                <div class="password-wrapper">
                    <input type="password" name="new_password" required minlength="8" placeholder="Minimal 8 karakter">
                    <button type="button" class="toggle-password" aria-label="Tampilkan password">
                        <i class="fa-solid fa-eye icon-eye"></i>
                        <i class="fa-solid fa-eye-slash icon-eye-off"></i>
                    </button>
                </div>
            </div>

            <!-- Konfirmasi Password -->
            <div class="form-group">
                <label>
                    <i class="fa-solid fa-shield-halved"></i>
                    Konfirmasi Password Baru
                </label>
                <div class="password-wrapper">
                    <input type="password" name="confirm_password" required minlength="8" placeholder="Ulangi password baru">
                    <button type="button" class="toggle-password" aria-label="Tampilkan password">
                        <i class="fa-solid fa-eye icon-eye"></i>
                        <i class="fa-solid fa-eye-slash icon-eye-off"></i>
                    </button>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">
                <i class="fa-solid fa-floppy-disk"></i>
                Simpan Password Baru
            </button>
        </form>

        <div class="info-box">
            <i class="fa-solid fa-lightbulb"></i>
            <div>
                <strong>Tips Keamanan:</strong> Gunakan kombinasi huruf besar, huruf kecil, angka, dan simbol. Jangan gunakan password yang sama dengan akun media sosial Anda.
            </div>
        </div>
    </div>
</div>

<!-- ✅ SCRIPT - PERBAIKAN LOGIKA -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    // ✅ Toggle Password Visibility (Font Awesome version)
    const toggleButtons = document.querySelectorAll('.toggle-password');
    
    toggleButtons.forEach(button => {
        button.addEventListener('click', function() {
            const wrapper = this.closest('.password-wrapper');
            const input = wrapper.querySelector('input');
            
            if (input.type === 'password') {
                input.type = 'text';
                this.classList.add('is-visible');
                this.setAttribute('aria-label', 'Sembunyikan password');
            } else {
                input.type = 'password';
                this.classList.remove('is-visible');
                this.setAttribute('aria-label', 'Tampilkan password');
            }
        });
    });
    
    // ✅ Focus ke input pertama saat halaman load
    const firstInput = document.querySelector('input[name="old_password"]');
    if (firstInput) firstInput.focus();
    
    console.log('✅ Change Password page loaded');
});
</script>

</body>
</html>