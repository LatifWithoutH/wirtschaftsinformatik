<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - SI Mitra DUDIKA | Universitas Islam Batik Surakarta</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --uniba-primary: #1a3a5c;
      --uniba-secondary: #8b6f47;
      --uniba-gold: #d4a017;
      --uniba-blue-light: #2c5282;
      --text-dark: #1e293b;
      --text-muted: #64748b;
      --bg-gradient: linear-gradient(135deg, #1a3a5c 0%, #0f2439 100%);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg-gradient);
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      padding: 20px;
      position: relative;
      overflow: hidden;
    }

    body::before, body::after {
      content: '';
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      z-index: 0;
      opacity: 0.35;
    }
    body::before {
      width: 400px; height: 400px;
      background: var(--uniba-gold);
      top: -100px; left: -100px;
      animation: float 8s ease-in-out infinite;
    }
    body::after {
      width: 300px; height: 300px;
      background: var(--uniba-secondary);
      bottom: -50px; right: -50px;
      animation: float 10s ease-in-out infinite reverse;
    }

    @keyframes float {
      0%, 100% { transform: translate(0, 0); }
      50% { transform: translate(20px, 30px); }
    }

    .login-box {
      background: rgba(255, 255, 255, 0.97);
      backdrop-filter: blur(10px);
      padding: 48px 40px;
      border-radius: 20px;
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
      width: 100%;
      max-width: 440px;
      text-align: center;
      position: relative;
      z-index: 1;
      border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .logo-area {
      margin-bottom: 24px;
    }
    
    .logo-uniba {
      width: 110px;
      height: auto;
      margin-bottom: 20px;
      display: block;
      margin-left: auto;
      margin-right: auto;
      filter: drop-shadow(0 4px 12px rgba(26, 58, 92, 0.25));
      transition: transform 0.3s ease;
    }

    .logo-uniba:hover {
      transform: scale(1.05);
    }

    .login-box h2 {
      font-family: 'Poppins', sans-serif;
      color: var(--uniba-primary);
      font-size: 1.5rem;
      margin-bottom: 8px;
      letter-spacing: -0.5px;
    }

    .login-box p {
      color: var(--text-muted);
      margin-bottom: 32px;
      font-size: 0.9rem;
      line-height: 1.5;
    }

    .login-box p strong {
      color: var(--uniba-primary);
      font-weight: 600;
      display: block;
      margin-top: 6px;
      font-size: 0.95rem;
    }

    .form-group {
      margin-bottom: 20px;
      text-align: left;
      position: relative;
    }

    .form-group label {
      display: block;
      margin-bottom: 8px;
      font-weight: 600;
      color: var(--text-dark);
      font-size: 0.85rem;
    }

    .input-wrapper {
      position: relative;
    }

    .input-wrapper svg {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      width: 18px;
      height: 18px;
      color: var(--text-muted);
      transition: color 0.3s;
    }

    .form-group input {
      width: 100%;
      padding: 14px 14px 14px 44px;
      border: 2px solid #e2e8f0;
      border-radius: 10px;
      font-size: 0.95rem;
      font-family: 'Inter', sans-serif;
      transition: all 0.3s ease;
      background: #f8fafc;
    }

    .form-group input:focus {
      outline: none;
      border-color: var(--uniba-primary);
      background: #fff;
      box-shadow: 0 0 0 4px rgba(26, 58, 92, 0.1);
    }

    .input-wrapper:focus-within svg {
      color: var(--uniba-primary);
    }

    button {
      width: 100%;
      padding: 14px;
      background: linear-gradient(135deg, var(--uniba-primary), var(--uniba-blue-light));
      color: white;
      border: none;
      border-radius: 10px;
      font-weight: 600;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.3s ease;
      margin-top: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-family: 'Poppins', sans-serif;
    }

    button:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(26, 58, 92, 0.35);
    }

    button:active {
      transform: translateY(0);
    }

    .error {
      color: #991b1b;
      background: #fef2f2;
      border: 1px solid #fecaca;
      padding: 12px 16px;
      border-radius: 10px;
      margin-bottom: 24px;
      font-size: 0.85rem;
      display: flex;
      align-items: center;
      gap: 10px;
      <% if (typeof error !== 'undefined' && error) { %>
        display: flex;
      <% } else { %>
        display: none;
      <% } %>
      animation: slideDown 0.4s ease;
    }

    @keyframes slideDown {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .footer {
      margin-top: 32px;
      font-size: 0.75rem;
      color: var(--text-muted);
      border-top: 1px solid #e2e8f0;
      padding-top: 20px;
      line-height: 1.6;
    }

    .footer strong {
      color: var(--uniba-primary);
      font-weight: 600;
    }

    @media (max-width: 480px) {
      .login-box {
        padding: 32px 24px;
      }
      .logo-uniba {
        width: 90px;
      }
      .login-box h2 {
        font-size: 1.3rem;
      }
    }
  </style>
</head>
<body>
  <div class="login-box">
    <div class="logo-area">
      <img src="/images/logo-uniba.png" alt="Logo Universitas Islam Batik Surakarta" class="logo-uniba">
      <h2>SI Mitra DUDIKA</h2>
      <p>
        Sistem Manajemen Kemitraan & Dokumen Legal<br>
        <strong>Universitas Islam Batik Surakarta</strong>
      </p>
    </div>
    
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error" id="errorMsg">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="12"></line>
          <line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
        <span><%= error %></span>
      </div>
    <% } %>
    
    <form action="/login" method="POST" id="loginForm">
      <div class="form-group">
        <label for="email">Email Fakultas/Humas</label>
        <div class="input-wrapper">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <input type="email" id="email" name="email" required placeholder="fakultas@uniba.ac.id" autocomplete="email">
        </div>
      </div>
      
      <div class="form-group">
        <label for="password">Password</label>
        <div class="input-wrapper">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
          <input type="password" id="password" name="password" required placeholder="Masukkan password Anda" autocomplete="current-password">
        </div>
      </div>
      
      <button type="submit" id="submitBtn">
        <span>Masuk ke Sistem</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </button>
    </form>
    
    <div class="footer">
      &copy; <%= new Date().getFullYear() %> <strong>Universitas Islam Batik Surakarta</strong><br>
      Sistem Informasi Kemitraan DUDIKA Terintegrasi
    </div>
  </div>

  <script>
    // Auto-hide error message after 5 seconds
    const err = document.getElementById('errorMsg');
    if (err && err.style.display !== 'none') {
      setTimeout(() => {
        err.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
        err.style.opacity = '0';
        err.style.transform = 'translateY(-10px)';
        setTimeout(() => {
          err.style.display = 'none';
        }, 500);
      }, 5000);
    }

    // Loading state on form submit
    const form = document.getElementById('loginForm');
    const btn = document.getElementById('submitBtn');
    
    form.addEventListener('submit', function() {
      btn.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="animation: spin 1s linear infinite;">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-opacity="0.25"></circle>
          <path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-linecap="round"></path>
        </svg>
        <span>Memproses...</span>
      `;
      btn.style.opacity = '0.8';
      btn.style.cursor = 'not-allowed';
      btn.disabled = true;
    });

    // Add spin animation
    const style = document.createElement('style');
    style.innerHTML = `@keyframes spin { 100% { transform: rotate(360deg); } }`;
    document.head.appendChild(style);
  </script>
</body>
</html>