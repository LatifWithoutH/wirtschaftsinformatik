<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
  <meta name="theme-color" content="#1a3a5c">
  <title>Login - SI Mitra DUDIKA | Universitas Islam Batik Surakarta</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@600;700&display=swap" rel="stylesheet">
<style>
    :root {
      --uniba-primary: #1a3a5c;
      --uniba-secondary: #8b6f47;
      --uniba-gold: #d4a017;
      --uniba-blue-light: #2c5282;
      --text-dark: #1e293b;
      --text-muted: #64748b;
      --bg-gradient: linear-gradient(135deg, #1a3a5c 0%, #0f2439 100%);
      --safe-top: env(safe-area-inset-top, 0px);
      --safe-bottom: env(safe-area-inset-bottom, 0px);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { -webkit-text-size-adjust: 100%; }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg-gradient);
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      min-height: 100dvh;
      padding: 14px;
      padding-top: calc(14px + var(--safe-top));
      padding-bottom: calc(14px + var(--safe-bottom));
      position: relative;
      overflow-x: hidden;
      overflow-y: auto;
    }

    body::before, body::after {
      content: '';
      position: fixed;
      border-radius: 50%;
      filter: blur(80px);
      z-index: 0;
      opacity: 0.18;
      pointer-events: none;
      will-change: transform;
    }
    
    body::before {
      width: 220px; height: 220px;
      background: var(--uniba-gold);
      top: -50px; left: -50px;
      animation: float 12s ease-in-out infinite;
    }
    
    body::after {
      width: 180px; height: 180px;
      background: var(--uniba-secondary);
      bottom: -35px; right: -35px;
      animation: float 15s ease-in-out infinite reverse;
    }

    @keyframes float {
      0%, 100% { transform: translate(0, 0); }
      50% { transform: translate(15px, 20px); }
    }

    .login-box {
      background: rgba(255, 255, 255, 0.97);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      padding: 26px 24px;
      border-radius: 16px;
      box-shadow: 0 14px 35px rgba(0, 0, 0, 0.22);
      width: 100%;
      max-width: 340px;
      text-align: center;
      position: relative;
      z-index: 1;
      border: 1px solid rgba(255, 255, 255, 0.2);
      margin: auto;
      animation: slideUp 0.5s ease;
    }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .logo-area { margin-bottom: 16px; }
    
    .logo-uniba {
      width: 65px;
      height: auto;
      margin-bottom: 10px;
      display: block;
      margin-left: auto;
      margin-right: auto;
      filter: drop-shadow(0 4px 12px rgba(26, 58, 92, 0.25));
      transition: transform 0.3s ease;
    }

    .logo-uniba:hover { transform: scale(1.05); }

    .login-box h2 {
      font-family: 'Poppins', sans-serif;
      color: var(--uniba-primary);
      font-size: 1.15rem;
      margin-bottom: 5px;
      letter-spacing: -0.5px;
    }

    .login-box p {
      color: var(--text-muted);
      margin-bottom: 18px;
      font-size: 0.78rem;
      line-height: 1.5;
    }

    .login-box p strong {
      color: var(--uniba-primary);
      font-weight: 600;
      display: block;
      margin-top: 3px;
      font-size: 0.82rem;
    }

    .form-group {
      margin-bottom: 12px;
      text-align: left;
      position: relative;
    }

    .form-group label {
      display: block;
      margin-bottom: 5px;
      font-weight: 600;
      color: var(--text-dark);
      font-size: 0.75rem;
    }

    .input-wrapper { position: relative; }

    .input-wrapper svg.input-icon {
      position: absolute;
      left: 11px;
      top: 50%;
      transform: translateY(-50%);
      width: 15px;
      height: 15px;
      color: var(--text-muted);
      transition: color 0.3s;
      pointer-events: none;
    }

    .form-group input {
      width: 100%;
      padding: 10px 11px 10px 36px;
      border: 2px solid #e2e8f0;
      border-radius: 8px;
      font-size: 13px;
      font-family: 'Inter', sans-serif;
      transition: all 0.3s ease;
      background: #f8fafc;
      color: var(--text-dark);
      -webkit-appearance: none;
      appearance: none;
    }

    .form-group input[type="password"],
    .form-group input.has-toggle {
      padding-right: 40px;
    }

    .form-group input:focus {
      outline: none;
      border-color: var(--uniba-primary);
      background: #fff;
      box-shadow: 0 0 0 3px rgba(26, 58, 92, 0.1);
    }

    .input-wrapper:focus-within svg.input-icon {
      color: var(--uniba-primary);
    }

    .toggle-password {
      position: absolute;
      right: 3px;
      top: 50%;
      transform: translateY(-50%);
      background: transparent;
      border: none;
      cursor: pointer;
      padding: 5px;
      border-radius: 6px;
      color: var(--text-muted);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.25s ease;
      -webkit-tap-highlight-color: transparent;
      touch-action: manipulation;
      min-height: auto;
      width: auto;
      margin-top: 0;
    }

    .toggle-password:hover {
      color: var(--uniba-primary);
      background: rgba(26, 58, 92, 0.08);
      transform: translateY(-50%) scale(1.05);
      box-shadow: none;
    }

    .toggle-password:active { transform: translateY(-50%) scale(0.95); }

    .toggle-password:focus {
      outline: none;
      box-shadow: 0 0 0 3px rgba(26, 58, 92, 0.15);
    }

    .toggle-password svg {
      width: 16px;
      height: 16px;
      display: block;
      pointer-events: none;
    }

    .toggle-password .icon-eye-off { display: none; }
    .toggle-password.is-visible .icon-eye { display: none; }
    .toggle-password.is-visible .icon-eye-off { display: block; }

    button[type="submit"] {
      width: 100%;
      padding: 10px;
      background: linear-gradient(135deg, var(--uniba-primary), var(--uniba-blue-light));
      color: white;
      border: none;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.85rem;
      cursor: pointer;
      transition: all 0.3s ease;
      margin-top: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 7px;
      font-family: 'Poppins', sans-serif;
      -webkit-tap-highlight-color: transparent;
      touch-action: manipulation;
      min-height: 38px;
    }

    button[type="submit"]:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 14px rgba(26, 58, 92, 0.28);
    }

    button[type="submit"]:active { transform: translateY(0); }

    .error {
      color: #991b1b;
      background: #fef2f2;
      border: 1px solid #fecaca;
      padding: 9px 12px;
      border-radius: 8px;
      margin-bottom: 14px;
      font-size: 0.75rem;
      display: flex;
      align-items: center;
      gap: 7px;
      <% if (typeof error !== 'undefined' && error) { %>
        display: flex;
      <% } else { %>
        display: none;
      <% } %>
      animation: slideDown 0.4s ease;
      text-align: left;
      flex-direction: column;
      align-items: flex-start;
    }

    .error svg { flex-shrink: 0; width: 14px; height: 14px; }

    /* ✅ COUNTDOWN TIMER STYLING */
    .countdown-container {
      display: flex;
      align-items: center;
      gap: 5px;
      margin-top: 7px;
      padding: 7px 10px;
      background: linear-gradient(135deg, rgba(220, 38, 38, 0.08), rgba(220, 38, 38, 0.03));
      border-left: 3px solid #dc2626;
      border-radius: 6px;
      font-size: 0.72rem;
      color: #991b1b;
      width: 100%;
    }

    .countdown-container .timer-icon {
      font-size: 0.9rem;
      animation: pulse 1.5s ease-in-out infinite;
    }

    .countdown-container .time-value {
      font-family: 'Courier New', monospace;
      font-weight: 700;
      font-size: 0.85rem;
      background: rgba(220, 38, 38, 0.15);
      padding: 2px 5px;
      border-radius: 4px;
      color: #dc2626;
      letter-spacing: 1px;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.6; transform: scale(1.15); }
    }

    @keyframes slideDown {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .footer {
      margin-top: 18px;
      font-size: 0.65rem;
      color: var(--text-muted);
      border-top: 1px solid #e2e8f0;
      padding-top: 12px;
      line-height: 1.5;
    }

    .footer strong {
      color: var(--uniba-primary);
      font-weight: 600;
    }

    /* ========== TABLET (768px) ========== */
    @media (max-width: 768px) {
      body {
        padding: 12px;
      }
      .login-box { padding: 24px 22px; max-width: 330px; }
    }

    /* ========== MOBILE KECIL (480px) ========== */
    @media (max-width: 480px) {
      body {
        padding: 10px;
        padding-top: calc(10px + var(--safe-top));
        padding-bottom: calc(10px + var(--safe-bottom));
      }
      .login-box { padding: 22px 18px; border-radius: 14px; max-width: 320px; }
      .logo-uniba { width: 58px; margin-bottom: 9px; }
      .login-box h2 { font-size: 1.05rem; }
      .login-box p { font-size: 0.75rem; margin-bottom: 16px; }
      .login-box p strong { font-size: 0.78rem; }
      .form-group { margin-bottom: 11px; }
      .form-group input { padding: 9px 10px 9px 34px; font-size: 13px; }
      .form-group input[type="password"],
      .form-group input.has-toggle { padding-right: 38px; }
      .input-wrapper svg.input-icon { left: 10px; width: 14px; height: 14px; }
      .toggle-password { right: 2px; padding: 4px; }
      .toggle-password svg { width: 15px; height: 15px; }
      button[type="submit"] { padding: 9px; font-size: 0.8rem; min-height: 36px; }
      .footer { margin-top: 16px; padding-top: 10px; font-size: 0.6rem; }
      body::before, body::after { filter: blur(50px); opacity: 0.15; }
      .countdown-container { font-size: 0.7rem; padding: 6px 9px; }
      .countdown-container .time-value { font-size: 0.8rem; }
    }

    /* ========== MOBILE SANGAT KECIL (360px) ========== */
    @media (max-width: 360px) {
      .login-box { padding: 18px 14px; max-width: 300px; }
      .logo-uniba { width: 52px; }
      .login-box h2 { font-size: 0.98rem; }
      .login-box p { font-size: 0.72rem; }
      .form-group input { padding: 8px 9px 8px 32px; font-size: 12px; }
      .form-group input[type="password"],
      .form-group input.has-toggle { padding-right: 36px; }
      .input-wrapper svg.input-icon { left: 9px; width: 13px; height: 13px; }
      .toggle-password { right: 1px; padding: 3px; }
      .toggle-password svg { width: 14px; height: 14px; }
    }

    /* ========== LANDSCAPE MOBILE ========== */
    @media (max-height: 500px) and (orientation: landscape) {
      body { align-items: flex-start; padding: 8px; }
      .login-box { padding: 14px 18px; margin: 8px auto; max-width: 320px; }
      .logo-area { margin-bottom: 8px; }
      .logo-uniba { width: 45px; margin-bottom: 7px; }
      .login-box h2 { font-size: 0.95rem; margin-bottom: 3px; }
      .login-box p { margin-bottom: 10px; font-size: 0.72rem; }
      .form-group { margin-bottom: 7px; }
      .footer { margin-top: 10px; padding-top: 8px; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        transition-duration: 0.01ms !important;
      }
    }
  </style>

</head>
<body>
  <div class="login-box">
    <div class="logo-area">
      <img src="/images/logo-uniba.png" alt="Logo Universitas Islam Batik Surakarta" class="logo-uniba">
      <h2>SI Mitra DUDIKA</h2>
      <p>
        Sistem Manajemen Kemitraan & Dokumen Legal<br>
        <strong>Universitas Islam Batik Surakarta</strong>
      </p>
    </div>
    
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error" id="errorMsg">
        <div style="display: flex; align-items: center; gap: 10px; width: 100%;">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="8" x2="12" y2="12"></line>
            <line x1="12" y1="16" x2="12.01" y2="16"></line>
          </svg>
          <span><%= error %></span>
        </div>
        
        <!-- ✅ COUNTDOWN TIMER (Hanya muncul jika locked = true) -->
        <% if (typeof locked !== 'undefined' && locked) { %>
          <div class="countdown-container" id="countdownContainer">
            <span class="timer-icon">⏳</span>
            <span>Silakan tunggu <span class="time-value" id="timeLeft">15:00</span> sebelum mencoba lagi.</span>
          </div>
        <% } %>
      </div>
    <% } %>
    
    <form action="/login" method="POST" id="loginForm" autocomplete="on">
      <div class="form-group">
        <label for="email">Email</label>
        <div class="input-wrapper">
          <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <input type="email" id="email" name="email" required placeholder="fakultas@uniba.ac.id" autocomplete="email" inputmode="email">
        </div>
      </div>
      
      <div class="form-group">
        <label for="password">Password</label>
        <div class="input-wrapper">
          <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
          <input type="password" id="password" name="password" class="has-toggle" required placeholder="Masukkan password Anda" autocomplete="current-password" aria-describedby="togglePasswordBtn">
          
          <button type="button" class="toggle-password" id="togglePasswordBtn" aria-label="Tampilkan password" aria-pressed="false" tabindex="0">
            <svg class="icon-eye" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
            <svg class="icon-eye-off" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path>
              <line x1="1" y1="1" x2="23" y2="23"></line>
            </svg>
          </button>
        </div>
      </div>
      
      <button type="submit" id="submitBtn">
        <span>Masuk ke Sistem</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </button>
    </form>
    
    <div class="footer">
      &copy; <%= new Date().getFullYear() %> <strong>Universitas Islam Batik Surakarta</strong><br>
      Sistem Informasi Kemitraan DUDIKA Terintegrasi
    </div>
  </div>

  <script>
    // Auto-hide error message after 5 seconds (KECUALI jika locked)
    const err = document.getElementById('errorMsg');
    const isLocked = <%= typeof locked !== 'undefined' && locked ? 'true' : 'false' %>;
    
    if (err && err.style.display !== 'none' && !isLocked) {
      setTimeout(() => {
        err.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
        err.style.opacity = '0';
        err.style.transform = 'translateY(-10px)';
        setTimeout(() => {
          err.style.display = 'none';
        }, 500);
      }, 5000);
    }

    // ===== TAMBAHAN: Toggle show/hide password =====
    const toggleBtn = document.getElementById('togglePasswordBtn');
    const passwordInput = document.getElementById('password');

    if (toggleBtn && passwordInput) {
      toggleBtn.addEventListener('click', function () {
        const isPassword = passwordInput.type === 'password';
        passwordInput.type = isPassword ? 'text' : 'password';
        this.classList.toggle('is-visible', isPassword);
        this.setAttribute('aria-label', isPassword ? 'Sembunyikan password' : 'Tampilkan password');
        this.setAttribute('aria-pressed', isPassword ? 'true' : 'false');
        passwordInput.focus();
      });

      toggleBtn.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          this.click();
        }
      });
    }

    // Loading state on form submit
    const form = document.getElementById('loginForm');
    const btn = document.getElementById('submitBtn');
    
    form.addEventListener('submit', function() {
      btn.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="animation: spin 1s linear infinite;">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-opacity="0.25"></circle>
          <path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-linecap="round"></path>
        </svg>
        <span>Memproses...</span>
      `;
      btn.style.opacity = '0.8';
      btn.style.cursor = 'not-allowed';
      btn.disabled = true;
    });

    const style = document.createElement('style');
    style.innerHTML = `@keyframes spin { 100% { transform: rotate(360deg); } }`;
    document.head.appendChild(style);

    if (err && err.style.display !== 'none' && !isLocked) {
      setTimeout(() => {
        err.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 100);
    }

    // ✅ COUNTDOWN TIMER & LOCK FORM
    <% if (typeof locked !== 'undefined' && locked) { %>
    (function() {
      let seconds = <%= typeof retryAfter !== 'undefined' ? retryAfter : 900 %>;
      const timeLeftEl = document.getElementById('timeLeft');
      const errorMsg = document.getElementById('errorMsg');
      const submitBtn = document.getElementById('submitBtn');
      const emailInput = document.getElementById('email');
      const passInput = document.getElementById('password');
      const toggleBtn = document.getElementById('togglePasswordBtn');
      
      // 1. Disable form & tombol login
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.style.opacity = '0.5';
        submitBtn.style.cursor = 'not-allowed';
        submitBtn.innerHTML = `
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
          </svg>
          <span>Akun Dikunci</span>
        `;
      }
      
      if (emailInput) emailInput.disabled = true;
      if (passInput) passInput.disabled = true;
      if (toggleBtn) toggleBtn.style.display = 'none';

      // 2. Fungsi update timer setiap detik
      function updateTimer() {
        if (seconds <= 0) {
          clearInterval(timerInterval);
          // Sembunyikan error & buka kembali form
          if (errorMsg) {
            errorMsg.style.transition = 'opacity 0.5s ease';
            errorMsg.style.opacity = '0';
            setTimeout(() => { errorMsg.style.display = 'none'; }, 500);
          }
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.style.opacity = '1';
            submitBtn.style.cursor = 'pointer';
            submitBtn.innerHTML = `
              <span>Masuk ke Sistem</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            `;
          }
          if (emailInput) {
            emailInput.disabled = false;
            emailInput.focus();
          }
          if (passInput) passInput.disabled = false;
          if (toggleBtn) toggleBtn.style.display = 'flex';
          
          // Optional: reload halaman setelah unlock
          setTimeout(() => { window.location.reload(); }, 1000);
          return;
        }
        
        const mins = Math.floor(seconds / 60);
        const secs = seconds % 60;
        if (timeLeftEl) {
          timeLeftEl.textContent = `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
        }
        seconds--;
      }

      // 3. Jalankan timer
      updateTimer();
      const timerInterval = setInterval(updateTimer, 1000);
    })();
    <% } %>
  </script>
</body>
</html>