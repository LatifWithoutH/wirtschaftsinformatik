<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - SI Mitra DUDIKA | Universitas Islam Batik</title>
  
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  
  <style>
    :root {
      --uniba-primary: #1a3a5c;
      --uniba-secondary: #8b6f47;
      --uniba-gold: #d4a017;
      --uniba-blue-light: #2c5282;
      --uniba-dark: #0f2439;
      
      --success: #10b981;
      --warning: #f59e0b;
      --danger: #ef4444;
      --expired: #64748b;
      
      --text-dark: #1e293b;
      --text-muted: #64748b;
      --bg-light: #f8fafc;
      --bg-card: rgba(255, 255, 255, 0.97);
      
      --sidebar-width: 280px;
      --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.04);
      --shadow-md: 0 4px 20px rgba(0, 0, 0, 0.08);
      --shadow-lg: 0 10px 40px rgba(0, 0, 0, 0.12);
    }
    
    * { box-sizing: border-box; margin: 0; padding: 0; }
    
    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg-light);
      color: var(--text-dark);
      line-height: 1.6;
      background-image: 
        radial-gradient(circle at 10% 20%, rgba(212, 160, 23, 0.03) 0%, transparent 40%),
        radial-gradient(circle at 90% 80%, rgba(26, 58, 92, 0.03) 0%, transparent 40%);
      min-height: 100vh;
      overflow-x: hidden;
    }
    
    /* ========== MAIN WRAPPER ========== */
    .main-wrapper {
      margin-left: var(--sidebar-width);
      transition: margin-left 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      min-height: 100vh;
    }
    
    .main-wrapper.expanded {
      margin-left: 0;
    }
    
    /* ========== PAGE HEADER (MINIMAL) ========== */
    .page-header {
      padding: 30px 40px 10px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 20px;
      margin-bottom: 20px;
    }
    
    .page-header h1 {
      font-family: 'Poppins', sans-serif;
      color: var(--uniba-primary);
      font-size: 1.9rem;
      font-weight: 700;
      letter-spacing: -0.5px;
      position: relative;
      padding-left: 18px;
    }
    
    .page-header h1::before {
      content: '';
      position: absolute;
      left: 0;
      top: 8px;
      bottom: 8px;
      width: 5px;
      background: linear-gradient(180deg, var(--uniba-gold), var(--uniba-primary));
      border-radius: 3px;
    }
    
    /* ========== ALERT SECTION ========== */
    .alert-section {
      background: linear-gradient(135deg, rgba(239, 68, 68, 0.03), rgba(245, 158, 11, 0.03));
      border-radius: 16px;
      padding: 25px;
      box-shadow: var(--shadow-md);
      margin: 0 40px 30px;
      border: 2px solid rgba(239, 68, 68, 0.15);
      position: relative;
      overflow: hidden;
    }
    
    .alert-section::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, var(--danger), var(--warning), var(--danger));
      background-size: 200% 100%;
      animation: gradientShift 3s ease infinite;
    }
    
    @keyframes gradientShift {
      0%, 100% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
    }
    
    .alert-section h3 {
      font-family: 'Poppins', sans-serif;
      color: var(--danger);
      margin-bottom: 20px;
      font-size: 1.2rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 10px;
      padding-bottom: 15px;
      border-bottom: 2px solid rgba(239, 68, 68, 0.1);
    }
    
    .alert-section h3 .pulse-dot {
      width: 10px;
      height: 10px;
      background: var(--danger);
      border-radius: 50%;
      animation: pulse 2s ease-in-out infinite;
    }
    
    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(1.2); }
    }
    
    .alert-list {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    
    .alert-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 20px;
      border-radius: 12px;
      border-left: 4px solid;
      transition: all 0.3s;
      cursor: pointer;
      background: white;
    }
    
    .alert-item:hover { 
      transform: translateX(5px);
      box-shadow: var(--shadow-md);
    }
    
    .alert-item.critical { 
      border-left-color: var(--danger); 
      background: linear-gradient(90deg, rgba(239, 68, 68, 0.08), white);
    }
    .alert-item.warning { 
      border-left-color: var(--warning); 
      background: linear-gradient(90deg, rgba(245, 158, 11, 0.08), white);
    }
    
    .alert-item .mitra-info h4 {
      font-size: 0.95rem;
      color: var(--text-dark);
      margin-bottom: 4px;
      font-weight: 600;
    }
    
    .alert-item .mitra-info p {
      font-size: 0.8rem;
      color: var(--text-muted);
    }
    
    .alert-item .mitra-info .email-mitra-asli {
      display: inline-block;
      margin-top: 4px;
      padding: 2px 8px;
      background: rgba(44, 82, 130, 0.08);
      border-radius: 4px;
      font-size: 0.75rem;
      color: var(--uniba-blue-light);
      font-weight: 500;
    }
    
    .alert-item .days-left {
      font-family: 'Poppins', sans-serif;
      font-weight: 700;
      padding: 8px 16px;
      border-radius: 20px;
      font-size: 0.85rem;
      white-space: nowrap;
    }
    
    .alert-item.critical .days-left { 
      background: var(--danger); 
      color: white;
      box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
      animation: shake 0.5s ease-in-out infinite;
    }
    
    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-2px); }
      75% { transform: translateX(2px); }
    }
    
    .alert-item.warning .days-left { 
      background: var(--warning); 
      color: white;
      box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3);
    }
    
    /* ========== STATS CARDS ========== */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
      padding: 0 40px 35px;
    }
    
    .stat-card {
      background: var(--bg-card);
      border-radius: 16px;
      padding: 24px;
      box-shadow: var(--shadow-sm);
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(226, 232, 240, 0.6);
    }
    
    .stat-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 4px;
      height: 100%;
    }
    
    .stat-card::after {
      content: '';
      position: absolute;
      top: -30px;
      right: -30px;
      width: 100px;
      height: 100px;
      border-radius: 50%;
      opacity: 0.08;
      transition: all 0.4s;
    }
    
    .stat-card:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow-lg);
    }
    
    .stat-card:hover::after {
      transform: scale(1.5);
      opacity: 0.12;
    }
    
    .stat-card.total::before { background: linear-gradient(180deg, var(--uniba-primary), var(--uniba-blue-light)); }
    .stat-card.total::after { background: var(--uniba-primary); }
    .stat-card.active::before { background: linear-gradient(180deg, var(--success), #34d399); }
    .stat-card.active::after { background: var(--success); }
    .stat-card.warning::before { background: linear-gradient(180deg, var(--warning), #fbbf24); }
    .stat-card.warning::after { background: var(--warning); }
    .stat-card.danger::before { background: linear-gradient(180deg, var(--danger), #f87171); }
    .stat-card.danger::after { background: var(--danger); }
    .stat-card.expired::before { background: linear-gradient(180deg, var(--expired), #94a3b8); }
    .stat-card.expired::after { background: var(--expired); }
    
    .stat-icon-wrapper {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 16px;
      font-size: 1.4rem;
    }
    
    .stat-card.total .stat-icon-wrapper { background: rgba(26, 58, 92, 0.1); }
    .stat-card.active .stat-icon-wrapper { background: rgba(16, 185, 129, 0.1); }
    .stat-card.warning .stat-icon-wrapper { background: rgba(245, 158, 11, 0.1); }
    .stat-card.danger .stat-icon-wrapper { background: rgba(239, 68, 68, 0.1); }
    .stat-card.expired .stat-icon-wrapper { background: rgba(100, 116, 139, 0.1); }
    
    .stat-card .stat-label { 
      font-size: 0.8rem; 
      color: var(--text-muted); 
      margin-bottom: 6px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 500;
    }
    
    .stat-card .stat-value { 
      font-family: 'Poppins', sans-serif;
      font-size: 2.2rem; 
      font-weight: 700; 
      color: var(--text-dark);
      line-height: 1;
      margin-bottom: 8px;
    }
    
    .stat-card .stat-change { 
      font-size: 0.75rem; 
      color: var(--text-muted);
      padding-top: 10px;
      border-top: 1px dashed #e2e8f0;
    }
    
    /* ========== CHARTS SECTION ========== */
    .charts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
      gap: 20px;
      padding: 0 40px 35px;
    }
    
    .chart-card {
      background: var(--bg-card);
      border-radius: 16px;
      padding: 25px;
      box-shadow: var(--shadow-sm);
      border: 1px solid rgba(226, 232, 240, 0.6);
      transition: all 0.3s;
    }
    
    .chart-card:hover {
      box-shadow: var(--shadow-md);
      transform: translateY(-2px);
    }
    
    .chart-card h3 {
      font-family: 'Poppins', sans-serif;
      color: var(--uniba-primary);
      margin-bottom: 20px;
      font-size: 1.1rem;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    
    .chart-card h3::after {
      content: '';
      flex: 1;
      height: 1px;
      background: linear-gradient(90deg, #e2e8f0, transparent);
    }
    
    /* ========== BUTTONS ========== */
    .quick-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      padding: 0 40px 40px;
    }
    
    .btn {
      padding: 12px 22px;
      background: linear-gradient(135deg, var(--uniba-primary), var(--uniba-blue-light));
      color: white;
      text-decoration: none;
      border-radius: 10px;
      font-weight: 600;
      border: none;
      cursor: pointer;
      transition: all 0.3s;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 0.9rem;
      font-family: 'Inter', sans-serif;
      box-shadow: 0 4px 12px rgba(26, 58, 92, 0.2);
    }
    
    .btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(26, 58, 92, 0.35);
    }
    
    .btn-success { 
      background: linear-gradient(135deg, var(--success), #34d399);
      box-shadow: 0 4px 12px rgba(16, 185, 129, 0.25);
    }
    .btn-success:hover { box-shadow: 0 6px 20px rgba(16, 185, 129, 0.4); }
    
    .btn-warning { 
      background: linear-gradient(135deg, var(--warning), #fbbf24);
      color: white;
      box-shadow: 0 4px 12px rgba(245, 158, 11, 0.25);
    }
    .btn-warning:hover { box-shadow: 0 6px 20px rgba(245, 158, 11, 0.4); }
    
    /* ========== MOBILE ========== */
    @media (max-width: 768px) {
      .main-wrapper { 
        margin-left: 0;
      }
      .main-wrapper.expanded { 
        margin-left: 0;
      }
      
      .page-header { 
        padding: 20px 20px 10px;
        flex-direction: column;
        align-items: flex-start;
      }
      
      .alert-section {
        margin: 0 20px 20px;
        padding: 20px;
      }
      
      .stats-grid {
        padding: 0 20px 25px;
        grid-template-columns: repeat(2, 1fr);
      }
      
      .charts-grid { 
        padding: 0 20px 25px;
        grid-template-columns: 1fr; 
      }
      
      .quick-actions {
        padding: 0 20px 30px;
      }
      
      .page-header h1 { font-size: 1.4rem; }
      .alert-item { flex-direction: column; align-items: flex-start; gap: 10px; }
      .alert-item .days-left { align-self: flex-end; }
    }
    
    /* ========== SCROLLBAR ========== */
    ::-webkit-scrollbar { 
      width: 10px;
      height: 10px;
    }
    
    ::-webkit-scrollbar-track { 
      background: #f1f5f9;
      border-radius: 5px;
    }
    
    ::-webkit-scrollbar-thumb { 
      background: linear-gradient(135deg, var(--uniba-primary), var(--uniba-blue-light));
      border-radius: 5px;
    }
    
    ::-webkit-scrollbar-thumb:hover { 
      background: var(--uniba-dark);
    }
  </style>
</head>
<body>
  <!-- Include Sidebar dari partials -->
  <%- include('partials/_sidebar') %>
  
  <!-- Main Wrapper -->
  <div class="main-wrapper">
    <!-- Page Header -->
    <div class="page-header">
      <h1>📊 Dashboard Overview</h1>
    </div>
    
    <!-- Alert Section -->
    <% if (segeraBerakhir && segeraBerakhir.length > 0) { %>
      <div class="alert-section">
        <h3>
          <span class="pulse-dot"></span>
          ⚠️ Peringatan: Mitra Segera Berakhir
          <span style="margin-left: auto; font-size: 0.85rem; font-weight: 500; color: var(--text-muted);">
            <%= segeraBerakhir.length %> mitra perlu perhatian
          </span>
        </h3>
        <div class="alert-list">
          <% segeraBerakhir.slice(0, 5).forEach(m => { %>
            <div class="alert-item <%= m.sisa_hari <= 7 ? 'critical' : 'warning' %>" onclick="window.location='/mitra/<%= m.id %>'">
              <div class="mitra-info">
                <h4><%= m.nama_instansi %></h4>
                <p>📞 <%= m.no_hp_kontak || '-' %> &nbsp;|&nbsp; ✉️ <%= m.email_fakultas || '-' %></p>
                <% if (m.email_mitra_asli) { %>
                  <span class="email-mitra-asli">🏢 Email Mitra: <%= m.email_mitra_asli %></span>
                <% } %>
              </div>
              <div class="days-left">
                <%= m.sisa_hari %> hari
              </div>
            </div>
          <% }) %>
        </div>
        <div class="quick-actions" style="padding: 20px 0 0;">
          <a href="/mitra" class="btn">📋 Lihat Semua Mitra</a>
          <% if (user && user.role === 'humas') { %>
            <a href="/mitra/tambah" class="btn btn-success">➕ Tambah Mitra Baru</a>
          <% } %>
        </div>
      </div>
    <% } %>
    
    <!-- Stats Cards -->
    <div class="stats-grid">
      <div class="stat-card total">
        <div class="stat-icon-wrapper">🏢</div>
        <div class="stat-label">Total Mitra</div>
        <div class="stat-value"><%= stats.total %></div>
        <div class="stat-change">Semua mitra terdaftar</div>
      </div>
      
      <div class="stat-card active">
        <div class="stat-icon-wrapper">✅</div>
        <div class="stat-label">Mitra Aktif</div>
        <div class="stat-value"><%= stats.aktif %></div>
        <div class="stat-change">> 30 hari lagi</div>
      </div>
      
      <div class="stat-card warning">
        <div class="stat-icon-wrapper">⚠️</div>
        <div class="stat-label">Akan Berakhir</div>
        <div class="stat-value"><%= stats.akan_berakhir %></div>
        <div class="stat-change">8-30 hari lagi</div>
      </div>
      
      <div class="stat-card danger">
        <div class="stat-icon-wrapper">🚨</div>
        <div class="stat-label">Segera Berakhir</div>
        <div class="stat-value"><%= stats.segera_berakhir %></div>
        <div class="stat-change">≤ 7 hari lagi</div>
      </div>
      
      <div class="stat-card expired">
        <div class="stat-icon-wrapper">⏰</div>
        <div class="stat-label">Expired</div>
        <div class="stat-value"><%= stats.expired %></div>
        <div class="stat-change">Perlu perpanjangan</div>
      </div>
    </div>
    
    <!-- Charts -->
    <div class="charts-grid">
      <div class="chart-card">
        <h3>📈 Status Mitra</h3>
        <canvas id="statusChart"></canvas>
      </div>
      
      <div class="chart-card">
        <h3>🎯 Distribusi Status</h3>
        <canvas id="pieChart"></canvas>
      </div>
    </div>
    
    <!-- Quick Actions -->
    <div class="quick-actions">
      <% if (user && user.role === 'humas') { %>
        <a href="/mitra/tambah" class="btn btn-success">➕ Tambah Mitra</a>
        <a href="/test-alert" class="btn btn-warning">🧪 Test Email Alert</a>
      <% } %>
      <a href="/mitra" class="btn">📋 Lihat Semua Mitra</a>
    </div>
  </div>
  
  <script>
    // Logic untuk Toggle Sidebar dengan Chevron
    const sidebarToggle = document.getElementById('sidebarToggle');
    const sidebar = document.querySelector('.sidebar');
    const mainWrapper = document.querySelector('.main-wrapper');

    if (sidebarToggle && sidebar) {
      sidebarToggle.addEventListener('click', () => {
        if (window.innerWidth <= 768) {
          sidebar.classList.toggle('active');
          sidebarToggle.classList.toggle('shifted');
        } else {
          sidebar.classList.toggle('hidden');
          mainWrapper.classList.toggle('expanded');
          sidebarToggle.classList.toggle('shifted');
        }
      });

      window.addEventListener('resize', () => {
        if (window.innerWidth > 768) {
          sidebar.classList.remove('active');
        } else {
          sidebar.classList.remove('hidden');
          mainWrapper.classList.remove('expanded');
          sidebarToggle.classList.remove('shifted');
        }
      });
    }
    
    // Chart.js Global Config
    Chart.defaults.font.family = "'Inter', sans-serif";
    Chart.defaults.color = '#64748b';
    
    // Bar Chart
    new Chart(document.getElementById('statusChart').getContext('2d'), {
      type: 'bar',
      data: {
        labels: ['Total', 'Aktif', 'Akan Berakhir', 'Segera', 'Expired'],
        datasets: [{
          label: 'Jumlah Mitra',
          data: [<%= stats.total %>, <%= stats.aktif %>, <%= stats.akan_berakhir %>, <%= stats.segera_berakhir %>, <%= stats.expired %>],
          backgroundColor: [
            'rgba(26, 58, 92, 0.85)',
            'rgba(16, 185, 129, 0.85)',
            'rgba(245, 158, 11, 0.85)',
            'rgba(239, 68, 68, 0.85)',
            'rgba(100, 116, 139, 0.85)'
          ],
          borderRadius: 10,
          borderSkipped: false,
          barThickness: 40
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: { 
          legend: { display: false },
          tooltip: {
            backgroundColor: 'rgba(15, 36, 57, 0.95)',
            padding: 12,
            cornerRadius: 8,
            titleFont: { weight: '600' }
          }
        },
        scales: { 
          y: { 
            beginAtZero: true, 
            ticks: { stepSize: 1 },
            grid: { color: 'rgba(226, 232, 240, 0.5)' }
          },
          x: {
            grid: { display: false }
          }
        }
      }
    });
    
    // Doughnut Chart
    new Chart(document.getElementById('pieChart').getContext('2d'), {
      type: 'doughnut',
      data: {
        labels: ['Aktif', 'Akan Berakhir', 'Segera Berakhir', 'Expired'],
        datasets: [{
          data: [<%= stats.aktif %>, <%= stats.akan_berakhir %>, <%= stats.segera_berakhir %>, <%= stats.expired %>],
          backgroundColor: [
            '#10b981',
            '#f59e0b',
            '#ef4444',
            '#64748b'
          ],
          borderWidth: 4,
          borderColor: '#ffffff',
          hoverOffset: 15
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        cutout: '65%',
        plugins: {
          legend: { 
            position: 'bottom', 
            labels: { 
              padding: 15, 
              usePointStyle: true,
              pointStyle: 'circle'
            } 
          },
          tooltip: {
            backgroundColor: 'rgba(15, 36, 57, 0.95)',
            padding: 12,
            cornerRadius: 8
          }
        }
      }
    });
  </script>
</body>
</html>