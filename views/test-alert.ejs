<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Test Alert Manual - SI Mitra DUDIKA | UNIBA</title>
  
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
  
  <style>
    :root {
      --uniba-primary: #1a3a5c;
      --uniba-secondary: #8b6f47;
      --uniba-gold: #d4a017;
      --uniba-blue-light: #2c5282;
      --uniba-dark: #0f2439;
      --success: #10b981;
      --warning: #f59e0b;
      --danger: #ef4444;
      --expired: #64748b;
      --text-dark: #1e293b;
      --text-muted: #64748b;
      --bg-light: #f8fafc;
      --bg-card: rgba(255, 255, 255, 0.97);
      --sidebar-width: 280px;
      --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.04);
      --shadow-md: 0 4px 20px rgba(0, 0, 0, 0.08);
      --shadow-lg: 0 10px 40px rgba(0, 0, 0, 0.12);
      --border: #e2e8f0;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg-light);
      color: var(--text-dark);
      line-height: 1.6;
      background-image: 
        radial-gradient(circle at 10% 20%, rgba(212, 160, 23, 0.03) 0%, transparent 40%),
        radial-gradient(circle at 90% 80%, rgba(26, 58, 92, 0.03) 0%, transparent 40%);
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ========== MAIN WRAPPER ========== */
    .main-wrapper {
      margin-left: var(--sidebar-width);
      transition: margin-left 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      min-height: 100vh;
    }
    
    .main-wrapper.expanded {
      margin-left: 0;
    }

    /* ========== PAGE HEADER ========== */
    .page-header {
      padding: 30px 40px 10px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 20px;
      margin-bottom: 30px;
    }
    
    .page-header h1 {
      font-family: 'Poppins', sans-serif;
      color: var(--uniba-primary);
      font-size: 1.9rem;
      font-weight: 700;
      letter-spacing: -0.5px;
      position: relative;
      padding-left: 18px;
    }
    
    .page-header h1::before {
      content: '';
      position: absolute;
      left: 0;
      top: 8px;
      bottom: 8px;
      width: 5px;
      background: linear-gradient(180deg, var(--uniba-gold), var(--uniba-primary));
      border-radius: 3px;
    }

    /* ========== INFO GRID ========== */
    .info-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      padding: 0 40px 30px;
    }
    
    .info-card {
      background: var(--bg-card);
      padding: 20px;
      border-radius: 16px;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      gap: 8px;
      transition: all 0.3s;
    }
    
    .info-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-md);
    }
    
    .info-label {
      font-size: 0.8rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 600;
    }
    
    .info-value {
      font-family: 'Poppins', sans-serif;
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--uniba-primary);
    }
    
    .info-value.highlight {
      color: var(--danger);
    }

    /* ========== TABLE SECTION ========== */
    .table-section {
      padding: 0 40px 30px;
      animation: fadeIn 0.5s ease;
    }
    
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    
    .table-container {
      background: var(--bg-card);
      border-radius: 16px;
      box-shadow: var(--shadow-lg);
      overflow: hidden;
      border: 1px solid var(--border);
    }
    
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.95rem;
      min-width: 800px;
    }
    
    thead {
      background: linear-gradient(135deg, var(--uniba-primary), var(--uniba-blue-light));
      color: white;
    }
    
    th {
      padding: 16px 20px;
      text-align: left;
      font-family: 'Poppins', sans-serif;
      font-weight: 600;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    
    td {
      padding: 16px 20px;
      border-bottom: 1px solid var(--border);
      vertical-align: middle;
    }
    
    tbody tr:last-child td {
      border-bottom: none;
    }
    
    tbody tr {
      transition: all 0.2s;
    }
    
    tbody tr:hover {
      background: rgba(26, 58, 92, 0.03);
    }
    
    .badge-days {
      display: inline-flex;
      align-items: center;
      padding: 6px 12px;
      border-radius: 20px;
      font-weight: 700;
      font-size: 0.85rem;
      background: rgba(239, 68, 68, 0.1);
      color: var(--danger);
    }
    
    .btn-send {
      padding: 8px 16px;
      background: linear-gradient(135deg, var(--uniba-primary), var(--uniba-blue-light));
      color: white;
      border: none;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.85rem;
      cursor: pointer;
      transition: all 0.3s;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      box-shadow: 0 2px 8px rgba(26, 58, 92, 0.2);
    }
    
    .btn-send:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(26, 58, 92, 0.3);
    }

    /* ========== EMPTY STATE ========== */
    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: var(--text-muted);
    }
    
    .empty-icon {
      font-size: 3rem;
      margin-bottom: 15px;
      opacity: 0.5;
    }
    
    .empty-state h3 {
      font-family: 'Poppins', sans-serif;
      color: var(--text-dark);
      margin-bottom: 8px;
    }

    /* ========== BUTTONS ========== */
    .btn-back {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 24px;
      background: white;
      color: var(--uniba-primary);
      text-decoration: none;
      border-radius: 10px;
      font-weight: 600;
      border: 2px solid var(--border);
      transition: all 0.3s;
      margin: 0 40px 40px;
    }
    
    .btn-back:hover {
      border-color: var(--uniba-primary);
      background: #f8fafc;
      transform: translateX(-5px);
    }

    /* ========== MOBILE ========== */
    @media (max-width: 768px) {
      .main-wrapper {
        margin-left: 0;
      }
      .main-wrapper.expanded {
        margin-left: 0;
      }
      
      .page-header {
        padding: 20px 20px 10px;
        flex-direction: column;
        align-items: flex-start;
      }
      
      .page-header h1 {
        font-size: 1.4rem;
      }
      
      .info-grid {
        padding: 0 20px 20px;
        grid-template-columns: repeat(2, 1fr);
      }
      
      .table-section {
        padding: 0 20px 20px;
      }
      
      .table-container {
        overflow-x: auto;
      }
      
      .btn-back {
        margin: 0 20px 30px;
      }
    }
    
    /* ========== SCROLLBAR ========== */
    ::-webkit-scrollbar {
      width: 10px;
      height: 10px;
    }
    
    ::-webkit-scrollbar-track {
      background: #f1f5f9;
      border-radius: 5px;
    }
    
    ::-webkit-scrollbar-thumb {
      background: linear-gradient(135deg, var(--uniba-primary), var(--uniba-blue-light));
      border-radius: 5px;
    }
    
    ::-webkit-scrollbar-thumb:hover {
      background: var(--uniba-dark);
    }
  </style>
</head>
<body>
  <!-- Include Sidebar dari partials -->
  <%- include('partials/_sidebar') %>
  
  <!-- Main Wrapper -->
  <div class="main-wrapper">
    <div class="page-header">
      <h1>🧪 Test Alert Manual</h1>
    </div>

    <!-- Info Cards -->
    <div class="info-grid">
      <div class="info-card">
        <span class="info-label">Waktu Server</span>
        <span class="info-value"><%= serverTime %></span>
      </div>
      <div class="info-card">
        <span class="info-label">Rentang Cek</span>
        <span class="info-value"><%= todayStr %> s/d <%= maxDateStr %></span>
      </div>
      <div class="info-card">
        <span class="info-label">Total Mitra</span>
        <span class="info-value"><%= totalMitra %></span>
      </div>
      <div class="info-card">
        <span class="info-label">Perlu Perhatian</span>
        <span class="info-value highlight"><%= inRangeCount %></span>
      </div>
    </div>

    <!-- Table Section -->
    <div class="table-section">
      <div class="table-container">
        <% if (mitraList && mitraList.length > 0) { %>
          <table>
            <thead>
              <tr>
                <th>Kode</th>
                <th>Instansi</th>
                <th>Email Fakultas</th>
                <th>Berakhir</th>
                <th>Sisa Hari</th>
                <th>Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% mitraList.forEach(m => { %>
                <tr>
                  <td><code style="background:#f1f5f9; padding:4px 8px; border-radius:6px; font-size:0.85rem; font-weight:600;"><%= m.kode_mitra %></code></td>
                  <td style="font-weight:600;"><%= m.nama_instansi %></td>
                  <td><a href="mailto:<%= m.email_fakultas %>" style="color:var(--uniba-primary); text-decoration:none; font-weight:500;"><%= m.email_fakultas %></a></td>
                  <td><%= new Date(m.tanggal_berakhir).toLocaleDateString('id-ID') %></td>
                  <td><span class="badge-days"><%= m.sisa_hari %> hari</span></td>
                  <td>
                    <form method="POST" action="/test-alert/send" style="display:inline;">
                      <input type="hidden" name="mitra_id" value="<%= m.id %>">
                      <button type="submit" class="btn-send">📧 Kirim Test</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } else { %>
          <div class="empty-state">
            <div class="empty-icon">✅</div>
            <h3>Tidak Ada Mitra yang Perlu Di-alert</h3>
            <p>Semua kerja sama masih aman atau belum ada data dalam rentang 30 hari ke depan.</p>
          </div>
        <% } %>
      </div>
    </div>

    <a href="/dashboard" class="btn-back">← Kembali ke Dashboard</a>
  </div>

  <script>
    // Logic Toggle Sidebar
    const sidebarToggle = document.getElementById('sidebarToggle');
    const sidebar = document.querySelector('.sidebar');
    const mainWrapper = document.querySelector('.main-wrapper');

    if (sidebarToggle && sidebar) {
      sidebarToggle.addEventListener('click', () => {
        if (window.innerWidth <= 768) {
          sidebar.classList.toggle('active');
          sidebarToggle.classList.toggle('shifted');
        } else {
          sidebar.classList.toggle('hidden');
          mainWrapper.classList.toggle('expanded');
          sidebarToggle.classList.toggle('shifted');
        }
      });

      window.addEventListener('resize', () => {
        if (window.innerWidth > 768) {
          sidebar.classList.remove('active');
        } else {
          sidebar.classList.remove('hidden');
          mainWrapper.classList.remove('expanded');
          sidebarToggle.classList.remove('shifted');
        }
      });
    }
  </script>
</body>
</html>