<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Test Alert Manual - SI Mitra DUDIKA | UNIBA</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
  
  <!-- ✅ FONT AWESOME 6 CDN -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  
  <style>
    :root {
      --uniba-primary: #1a3a5c;
      --uniba-secondary: #8b6f47;
      --uniba-gold: #d4a017;
      --uniba-blue-light: #2c5282;
      --uniba-dark: #0f2439;
      --success: #10b981;
      --warning: #f59e0b;
      --danger: #ef4444;
      --expired: #64748b;
      --text-dark: #1e293b;
      --text-muted: #64748b;
      --bg-light: #f8fafc;
      --bg-card: rgba(255, 255, 255, 0.97);
      --sidebar-width: 280px;
      --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.04);
      --shadow-md: 0 4px 20px rgba(0, 0, 0, 0.08);
      --shadow-lg: 0 10px 40px rgba(0, 0, 0, 0.12);
      --border: #e2e8f0;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg-light);
      color: var(--text-dark);
      line-height: 1.6;
      background-image: 
        radial-gradient(circle at 10% 20%, rgba(212, 160, 23, 0.03) 0%, transparent 40%),
        radial-gradient(circle at 90% 80%, rgba(26, 58, 92, 0.03) 0%, transparent 40%);
      min-height: 100vh;
      overflow-x: hidden;
    }

    .main-wrapper {
      margin-left: var(--sidebar-width);
      transition: margin-left 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      min-height: 100vh;
    }
    .main-wrapper.expanded { margin-left: 0; }

    /* ✅ PAGE HEADER (DIKECILKAN) */
    .page-header {
      padding: 24px 40px 8px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 16px;
      margin-bottom: 24px;
    }
    .page-header h1 {
      font-family: 'Poppins', sans-serif;
      color: var(--uniba-primary);
      font-size: 1.55rem;
      font-weight: 700;
      letter-spacing: -0.5px;
      position: relative;
      padding-left: 16px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .page-header h1::before {
      content: '';
      position: absolute;
      left: 0;
      top: 6px;
      bottom: 6px;
      width: 4px;
      background: linear-gradient(180deg, var(--uniba-gold), var(--uniba-primary));
      border-radius: 3px;
    }
    .page-header h1 i {
      color: var(--uniba-gold);
      font-size: 1.3rem;
    }

@media (max-width: 768px) {
  .page-header {
    padding: 23px !important;
    padding-left: 60px !important; /* KURANGI dari 75px jadi 60px */
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px; /* KURANGI gap dari 12px jadi 8px */
    flex-wrap: nowrap;
  }
  
  .page-header h1 {
    font-size: 1.15rem !important;
    padding-left: 0 !important;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 6px; /* KURANGI gap icon-judul dari 8px jadi 6px */
    white-space: nowrap;
  }
  
  .page-header h1::before {
    content: '';
    position: static !important;
    width: 3px !important;
    height: 24px !important;
    background: linear-gradient(180deg, var(--uniba-gold), var(--uniba-primary)) !important;
    border-radius: 2px;
    flex-shrink: 0;
    margin-right: 2px; /* KURANGI margin dari 4px jadi 2px */
  }
}

    /* ✅ INFO GRID (DIKECILKAN) */
    .info-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 16px;
      padding: 0 40px 24px;
    }
    .info-card {
      background: var(--bg-card);
      padding: 16px;
      border-radius: 12px;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      gap: 6px;
      transition: all 0.3s;
    }
    .info-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-md);
    }
    .info-label {
      font-size: 0.7rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 600;
    }
    .info-value {
      font-family: 'Poppins', sans-serif;
      font-size: 1rem;
      font-weight: 600;
      color: var(--uniba-primary);
    }
    .info-value.highlight { color: var(--danger); }

    /* ✅ TABLE SECTION (DIKECILKAN) */
    .table-section {
      padding: 0 40px 24px;
      animation: fadeIn 0.5s ease;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .table-container {
      background: var(--bg-card);
      border-radius: 14px;
      box-shadow: var(--shadow-lg);
      overflow: hidden;
      border: 1px solid var(--border);
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
      min-width: 1000px;
    }
    thead {
      background: linear-gradient(135deg, var(--uniba-primary), var(--uniba-blue-light));
      color: white;
    }
    th {
      padding: 12px 16px;
      text-align: left;
      font-family: 'Poppins', sans-serif;
      font-weight: 600;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.7px;
    }
    td {
      padding: 12px 16px;
      border-bottom: 1px solid var(--border);
      vertical-align: middle;
    }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr { transition: all 0.2s; }
    tbody tr:hover { background: rgba(26, 58, 92, 0.04); }
    
    /* ✅ BADGE DAYS (DIKECILKAN) */
    .badge-days {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 5px 10px;
      border-radius: 20px;
      font-weight: 700;
      font-size: 12px;
      background: rgba(239, 68, 68, 0.1);
      color: var(--danger);
    }
    .badge-days i {
      font-size: 0.75rem;
    }

    /* ========== EMAIL CELLS ========== */
    .email-pj {
      color: var(--uniba-primary);
      text-decoration: none;
      font-weight: 500;
      transition: all 0.2s;
      font-size: 12px;
    }
    .email-pj:hover {
      color: var(--uniba-blue-light);
      text-decoration: underline;
    }
    .email-pj-label {
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 0.65rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 2px;
    }
    .email-pj-label i {
      font-size: 0.7rem;
    }
    .email-mitra {
      color: var(--success);
      text-decoration: none;
      font-weight: 500;
      font-size: 12px;
      transition: all 0.2s;
    }
    .email-mitra:hover {
      color: #059669;
      text-decoration: underline;
    }
    .email-mitra-empty {
      color: var(--text-muted);
      font-size: 12px;
      font-style: italic;
    }

    /* ✅ TOMBOL KIRIM (DIKECILKAN) */
    .btn-send {
      padding: 8px 14px;
      background: linear-gradient(135deg, var(--uniba-primary), var(--uniba-blue-light));
      color: white;
      border: none;
      border-radius: 8px;
      font-weight: 600;
      font-size: 12px;
      cursor: pointer;
      transition: all 0.3s;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      box-shadow: 0 4px 12px rgba(26, 58, 92, 0.2);
      font-family: 'Inter', sans-serif;
      position: relative;
      overflow: hidden;
    }
    .btn-send i {
      font-size: 0.8rem;
      transition: transform 0.3s ease;
    }
    .btn-send:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(26, 58, 92, 0.35);
    }
    .btn-send:hover:not(:disabled) i {
      transform: scale(1.15);
    }
    .btn-send:disabled {
      opacity: 0.7;
      cursor: not-allowed;
    }
    .btn-send.sending {
      background: linear-gradient(135deg, var(--text-muted), #94a3b8);
    }
    .btn-send.sent {
      background: linear-gradient(135deg, var(--success), #34d399);
    }

    /* Spinner */
    .spinner {
      display: none;
      width: 12px;
      height: 12px;
      border: 2px solid rgba(255, 255, 255, 0.3);
      border-top-color: white;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    .btn-send.sending .spinner { display: inline-block; }
    .btn-send.sending .btn-text { display: none; }
    .btn-send.sending .btn-loading { display: inline; }
    .btn-loading { display: none; }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    /* ✅ MODAL HASIL (DIKECILKAN) */
    .modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(15, 36, 57, 0.7);
      backdrop-filter: blur(4px);
      display: none;
      justify-content: center;
      align-items: center;
      z-index: 2000;
      animation: fadeIn 0.3s ease;
    }
    .modal-overlay.show { display: flex; }

    .modal-box {
      background: white;
      border-radius: 18px;
      padding: 32px;
      max-width: 480px;
      width: 90%;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
      animation: slideUp 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      overflow: hidden;
      text-align: center;
    }
    .modal-box::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
    }
    .modal-box.success::before {
      background: linear-gradient(90deg, var(--success), #34d399, var(--success));
    }
    .modal-box.error::before {
      background: linear-gradient(90deg, var(--danger), #f87171, var(--danger));
    }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(30px) scale(0.95); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .modal-icon {
      width: 64px;
      height: 64px;
      margin: 0 auto 16px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      animation: bounceIn 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    }
    @keyframes bounceIn {
      0% { transform: scale(0); }
      50% { transform: scale(1.2); }
      100% { transform: scale(1); }
    }
    .modal-icon.success {
      background: linear-gradient(135deg, rgba(16, 185, 129, 0.15), rgba(52, 211, 153, 0.15));
      color: var(--success);
    }
    .modal-icon.error {
      background: linear-gradient(135deg, rgba(239, 68, 68, 0.15), rgba(248, 113, 113, 0.15));
      color: var(--danger);
    }

    .modal-title {
      font-family: 'Poppins', sans-serif;
      font-size: 1.25rem;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .modal-title.success { color: var(--success); }
    .modal-title.error { color: var(--danger); }

    .modal-message {
      color: var(--text-muted);
      font-size: 0.88rem;
      line-height: 1.6;
      margin-bottom: 16px;
    }

    .modal-detail {
      background: linear-gradient(135deg, rgba(26, 58, 92, 0.05), rgba(44, 82, 130, 0.05));
      border-radius: 10px;
      padding: 14px;
      margin: 16px 0;
      border-left: 4px solid var(--uniba-primary);
      text-align: left;
    }
    .modal-detail-row {
      display: flex;
      justify-content: space-between;
      padding: 6px 0;
      font-size: 0.82rem;
      align-items: center;
    }
    .modal-detail-row:not(:last-child) {
      border-bottom: 1px dashed rgba(226, 232, 240, 0.8);
    }
    .modal-detail-row i {
      margin-right: 5px;
      font-size: 0.75rem;
    }
    .modal-detail-label {
      color: var(--text-muted);
      font-weight: 500;
      flex-shrink: 0;
    }
    .modal-detail-value {
      color: var(--text-dark);
      font-weight: 600;
      text-align: right;
      word-break: break-word;
      margin-left: 10px;
    }

    .modal-actions {
      margin-top: 20px;
    }
    .btn-close-modal {
      padding: 10px 28px;
      background: linear-gradient(135deg, var(--uniba-primary), var(--uniba-blue-light));
      color: white;
      border: none;
      border-radius: 9px;
      font-weight: 600;
      font-size: 0.88rem;
      cursor: pointer;
      transition: all 0.3s;
      font-family: 'Inter', sans-serif;
      box-shadow: 0 4px 12px rgba(26, 58, 92, 0.2);
    }
    .btn-close-modal:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(26, 58, 92, 0.35);
    }

    .countdown-text {
      font-size: 0.75rem;
      color: var(--text-muted);
      margin-top: 10px;
    }

    /* ✅ EMPTY STATE (DIKECILKAN) */
    .empty-state {
      text-align: center;
      padding: 50px 20px;
      color: var(--text-muted);
    }
    .empty-icon {
      font-size: 2.5rem;
      margin-bottom: 12px;
      opacity: 0.5;
      color: var(--success);
    }
    .empty-state h3 {
      font-family: 'Poppins', sans-serif;
      color: var(--text-dark);
      margin-bottom: 6px;
      font-size: 1.1rem;
    }
    .empty-state p {
      font-size: 0.85rem;
    }

    /* ✅ BTN BACK (DIKECILKAN) */
    .btn-back {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 10px 20px;
      background: white;
      color: var(--uniba-primary);
      text-decoration: none;
      border-radius: 9px;
      font-weight: 600;
      border: 2px solid var(--border);
      transition: all 0.3s;
      margin: 0 40px 32px;
      font-size: 13px;
    }
    .btn-back i {
      font-size: 0.85rem;
      transition: transform 0.3s ease;
    }
    .btn-back:hover {
      border-color: var(--uniba-primary);
      background: #f8fafc;
      transform: translateX(-5px);
    }
    .btn-back:hover i {
      transform: translateX(-3px);
    }

    /* ✅ INFO BADGE GAS (DIKECILKAN) */
    .gas-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 12px;
      background: linear-gradient(135deg, rgba(16, 185, 129, 0.1), rgba(52, 211, 153, 0.1));
      border: 1px solid rgba(16, 185, 129, 0.3);
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--success);
    }
    .gas-badge::before {
      content: '';
      width: 7px;
      height: 7px;
      background: var(--success);
      border-radius: 50%;
      animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(1.2); }
    }

    @media (max-width: 768px) {
      .main-wrapper { margin-left: 0; }
      .main-wrapper.expanded { margin-left: 0; }
      .page-header { padding: 18px 20px 8px; flex-direction: column; align-items: flex-start; }
      .page-header h1 { font-size: 1.3rem; }
      .info-grid { padding: 0 20px 16px; grid-template-columns: repeat(2, 1fr); }
      .table-section { padding: 0 20px 16px; }
      .table-container { overflow-x: auto; }
      .btn-back { margin: 0 20px 24px; }
      .modal-box { padding: 24px 18px; }
    }
  </style>
</head>
<body>
  <%- include('partials/_sidebar') %>
  
  <div class="main-wrapper">
    <div class="page-header">
      <div>
        <h1>
          <i class="fa-solid fa-flask"></i>
          Test Alert Manual
        </h1>
        <div class="gas-badge" style="margin-top: 10px;">
          Dikirim via Google Apps Script
        </div>
      </div>
    </div>

    <div class="info-grid">
      <div class="info-card">
        <span class="info-label">Waktu Server</span>
        <span class="info-value"><%= serverTime %></span>
      </div>
      <div class="info-card">
        <span class="info-label">Rentang Cek</span>
        <span class="info-value"><%= todayStr %> s/d <%= maxDateStr %></span>
      </div>
      <div class="info-card">
        <span class="info-label">Total Mitra</span>
        <span class="info-value"><%= totalMitra %></span>
      </div>
      <div class="info-card">
        <span class="info-label">Perlu Perhatian</span>
        <span class="info-value highlight"><%= inRangeCount %></span>
      </div>
    </div>

    <div class="table-section">
      <div class="table-container">
        <% if (mitraList && mitraList.length > 0) { %>
          <table>
            <thead>
              <tr>
                <th>Kode</th>
                <th>Instansi</th>
                <th>Email Penanggung Jawab</th>
                <th>Email Resmi Mitra</th>
                <th>Berakhir</th>
                <th>Sisa Hari</th>
                <th>Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% mitraList.forEach(m => { %>
                <tr id="row-<%= m.id %>">
                  <td>
                    <code style="background:#f1f5f9; padding:4px 8px; border-radius:6px; font-size:11px; font-weight:600;">
                      <%= m.kode_mitra %>
                    </code>
                  </td>
                  <td style="font-weight:600; font-size: 13px;"><%= m.nama_instansi %></td>
                  <td>
                    <span class="email-pj-label">
                      <i class="fa-solid fa-envelope"></i>
                      Penerima
                    </span>
                    <a href="mailto:<%= m.email_fakultas %>" class="email-pj">
                      <%= m.email_fakultas || '-' %>
                    </a>
                  </td>
                  <td>
                    <% if (m.email_mitra_asli) { %>
                      <span class="email-pj-label">
                        <i class="fa-solid fa-building"></i>
                        Referensi
                      </span>
                      <a href="mailto:<%= m.email_mitra_asli %>" class="email-mitra">
                        <%= m.email_mitra_asli %>
                      </a>
                    <% } else { %>
                      <span class="email-mitra-empty">Belum diisi</span>
                    <% } %>
                  </td>
                  <td style="font-size: 12px;">
                    <%= new Date(m.tanggal_berakhir).toLocaleDateString('id-ID') %>
                  </td>
                  <td>
                    <span class="badge-days">
                      <i class="fa-solid fa-clock"></i>
                      <%= m.sisa_hari %> hari
                    </span>
                  </td>
                  <td>
                    <button type="button" 
                            class="btn-send" 
                            data-mitra-id="<%= m.id %>"
                            data-mitra-name="<%= m.nama_instansi %>"
                            data-mitra-email="<%= m.email_fakultas || '' %>"
                            data-mitra-email-asli="<%= m.email_mitra_asli || '' %>"
                            data-sisa-hari="<%= m.sisa_hari %>"
                            onclick="sendTestEmail(this)">
                      <span class="spinner"></span>
                      <span class="btn-text">
                        <i class="fa-solid fa-paper-plane"></i>
                        Kirim Test
                      </span>
                      <span class="btn-loading">Mengirim...</span>
                    </button>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } else { %>
          <div class="empty-state">
            <div class="empty-icon">
              <i class="fa-solid fa-circle-check"></i>
            </div>
            <h3>Tidak Ada Mitra yang Perlu Di-alert</h3>
            <p>Semua kerja sama masih aman atau belum ada data dalam rentang 30 hari ke depan.</p>
          </div>
        <% } %>
      </div>
    </div>

    <a href="/dashboard" class="btn-back">
      <i class="fa-solid fa-arrow-left"></i>
      Kembali ke Dashboard
    </a>
  </div>

  <!-- Modal Hasil -->
  <div class="modal-overlay" id="resultModal">
    <div class="modal-box" id="modalBox">
      <div class="modal-icon" id="modalIcon">
        <i class="fa-solid fa-circle-check"></i>
      </div>
      <h2 class="modal-title" id="modalTitle">Berhasil!</h2>
      <p class="modal-message" id="modalMessage">Email alert berhasil dikirim.</p>
      
      <div class="modal-detail" id="modalDetail" style="display:none;">
        <div class="modal-detail-row">
          <span class="modal-detail-label">
            <i class="fa-solid fa-envelope"></i>
            Email Penerima (PJ)
          </span>
          <span class="modal-detail-value" id="detailEmailPJ">-</span>
        </div>
        <div class="modal-detail-row" id="detailEmailMitraRow" style="display:none;">
          <span class="modal-detail-label">
            <i class="fa-solid fa-building"></i>
            Email Mitra (Info)
          </span>
          <span class="modal-detail-value" id="detailEmailMitra" style="color: var(--success);">-</span>
        </div>
        <div class="modal-detail-row">
          <span class="modal-detail-label">
            <i class="fa-solid fa-building-columns"></i>
            Instansi
          </span>
          <span class="modal-detail-value" id="detailInstansi">-</span>
        </div>
        <div class="modal-detail-row">
          <span class="modal-detail-label">
            <i class="fa-solid fa-clock"></i>
            Sisa Waktu
          </span>
          <span class="modal-detail-value" id="detailSisaHari">-</span>
        </div>
      </div>

      <div class="modal-actions">
        <button type="button" class="btn-close-modal" onclick="closeModal()">Tutup</button>
      </div>
      <div class="countdown-text" id="countdownText">
        Modal akan tertutup otomatis dalam <span id="countdown">5</span> detik
      </div>
    </div>
  </div>

  <script>
    // ========== URL GAS WEB APP ==========
    let GAS_WEB_APP_ALERT;
    fetch('/api/gas-url')
      .then(r => r.json())
      .then(data => { GAS_WEB_APP_ALERT = data.url; })
      .catch(err => console.error('Gagal load GAS URL:', err));

    // ========== KIRIM EMAIL VIA GAS ==========
    let countdownInterval;

    async function sendTestEmail(button) {
      const mitraId = button.dataset.mitraId;
      const mitraName = button.dataset.mitraName;
      const mitraEmail = button.dataset.mitraEmail;
      const mitraEmailAsli = button.dataset.mitraEmailAsli;
      const sisaHari = button.dataset.sisaHari;

      if (!mitraEmail) {
        showModal({
          success: false,
          title: 'Data Tidak Lengkap',
          message: 'Email Penanggung Jawab (Fakultas) belum diisi. Silakan lengkapi data mitra terlebih dahulu.',
          data: null
        });
        return;
      }

      button.disabled = true;
      button.classList.add('sending');

      try {
        const response = await fetch(GAS_WEB_APP_ALERT, {
          method: 'POST',
          body: JSON.stringify({
            mitra_id: mitraId,
            nama_instansi: mitraName,
            email_fakultas: mitraEmail,
            email_mitra_asli: mitraEmailAsli,
            sisa_hari: sisaHari
          }),
          redirect: 'follow'
        });

        const result = await response.json();

        if (result.success) {
          button.classList.remove('sending');
          button.classList.add('sent');
          button.innerHTML = '<i class="fa-solid fa-circle-check"></i> Terkirim via GAS';
          
          showModal({
            success: true,
            title: 'Email Berhasil Dikirim via GAS!',
            message: 'Notifikasi peringatan telah dikirim ke Email Penanggung Jawab. Silakan cek inbox (atau folder spam) dalam beberapa menit.',
            data: {
              email_pj: result.data.email,
              email_mitra: mitraEmailAsli || null,
              nama_instansi: result.data.nama_instansi,
              sisa_hari: result.data.sisa_hari
            }
          });
        } else {
          button.classList.remove('sending');
          button.disabled = false;
          button.innerHTML = '<i class="fa-solid fa-rotate"></i> Coba Lagi';
          
          showModal({
            success: false,
            title: 'Gagal Mengirim Email',
            message: result.message || 'Terjadi kesalahan saat mengirim email via GAS.',
            data: null
          });
        }
      } catch (err) {
        console.error('Error:', err);
        button.classList.remove('sending');
        button.disabled = false;
        button.innerHTML = '<i class="fa-solid fa-rotate"></i> Coba Lagi';
        
        showModal({
          success: false,
          title: 'Koneksi ke GAS Gagal',
          message: 'Tidak dapat terhubung ke Google Apps Script. Pastikan URL Web App sudah benar dan deployment aktif.',
          data: null
        });
      }
    }

    // ========== MODAL FUNCTIONS ==========
    function showModal({ success, title, message, data }) {
      const modal = document.getElementById('resultModal');
      const modalBox = document.getElementById('modalBox');
      const icon = document.getElementById('modalIcon');
      const titleEl = document.getElementById('modalTitle');
      const messageEl = document.getElementById('modalMessage');
      const detailEl = document.getElementById('modalDetail');
      const countdownText = document.getElementById('countdownText');

      modalBox.classList.remove('success', 'error');
      icon.classList.remove('success', 'error');
      titleEl.classList.remove('success', 'error');

      if (success) {
        modalBox.classList.add('success');
        icon.classList.add('success');
        titleEl.classList.add('success');
        icon.innerHTML = '<i class="fa-solid fa-circle-check"></i>';
        
        if (data) {
          document.getElementById('detailEmailPJ').textContent = data.email_pj || '-';
          
          const emailMitraRow = document.getElementById('detailEmailMitraRow');
          if (data.email_mitra) {
            document.getElementById('detailEmailMitra').textContent = data.email_mitra;
            emailMitraRow.style.display = 'flex';
          } else {
            emailMitraRow.style.display = 'none';
          }
          
          document.getElementById('detailInstansi').textContent = data.nama_instansi || '-';
          document.getElementById('detailSisaHari').textContent = (data.sisa_hari || 0) + ' hari';
          detailEl.style.display = 'block';
        } else {
          detailEl.style.display = 'none';
        }
        countdownText.style.display = 'block';
      } else {
        modalBox.classList.add('error');
        icon.classList.add('error');
        titleEl.classList.add('error');
        icon.innerHTML = '<i class="fa-solid fa-circle-xmark"></i>';
        detailEl.style.display = 'none';
        countdownText.style.display = 'none';
      }

      titleEl.textContent = title;
      messageEl.textContent = message;
      modal.classList.add('show');

      if (success) {
        startCountdown(5);
      }
    }

    function closeModal() {
      const modal = document.getElementById('resultModal');
      modal.classList.remove('show');
      if (countdownInterval) {
        clearInterval(countdownInterval);
      }
    }

    function startCountdown(seconds) {
      const countdownEl = document.getElementById('countdown');
      let remaining = seconds;
      countdownEl.textContent = remaining;

      if (countdownInterval) clearInterval(countdownInterval);
      
      countdownInterval = setInterval(() => {
        remaining--;
        countdownEl.textContent = remaining;
        if (remaining <= 0) {
          clearInterval(countdownInterval);
          closeModal();
        }
      }, 1000);
    }

    document.getElementById('resultModal').addEventListener('click', function(e) {
      if (e.target === this) closeModal();
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeModal();
    });
  </script>
</body>
</html>