<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= action === 'tambah' ? 'Tambah' : 'Edit' %> Mitra - SI Mitra DUDIKA | UNIBA</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --uniba-primary: #1a3a5c;
      --uniba-secondary: #8b6f47;
      --uniba-gold: #d4a017;
      --uniba-blue-light: #2c5282;
      --uniba-dark: #0f2439;
      
      --success: #10b981;
      --danger: #ef4444;
      --warning: #f59e0b;
      
      --text-dark: #1e293b;
      --text-muted: #64748b;
      --bg-light: #f8fafc;
      --border: #e2e8f0;
      
      --sidebar-width: 280px;
      --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.04);
      --shadow-md: 0 4px 20px rgba(0, 0, 0, 0.08);
      --shadow-lg: 0 10px 40px rgba(0, 0, 0, 0.12);
    }
    
    * { box-sizing: border-box; margin: 0; padding: 0; }
    
    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg-light);
      color: var(--text-dark);
      line-height: 1.6;
      min-height: 100vh;
      background-image: 
        radial-gradient(circle at 10% 20%, rgba(212, 160, 23, 0.03) 0%, transparent 40%),
        radial-gradient(circle at 90% 80%, rgba(26, 58, 92, 0.03) 0%, transparent 40%);
      overflow-x: hidden;
    }
    
    /* ========== MAIN WRAPPER ========== */
    .main-wrapper {
      margin-left: var(--sidebar-width);
      transition: margin-left 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 40px 20px;
    }
    
    .main-wrapper.expanded {
      margin-left: 0;
    }
    
    /* ========== FORM CONTAINER ========== */
    .form-container {
      width: 100%;
      max-width: 800px;
      background: rgba(255, 255, 255, 0.97);
      padding: 40px;
      border-radius: 20px;
      box-shadow: var(--shadow-lg);
      border: 1px solid rgba(226, 232, 240, 0.6);
      backdrop-filter: blur(10px);
      animation: slideUp 0.5s ease;
    }
    
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    
    /* ========== HEADER ========== */
    .form-header {
      text-align: center;
      margin-bottom: 35px;
      position: relative;
      padding-bottom: 20px;
      border-bottom: 2px solid #f1f5f9;
    }
    
    .form-header .logo-icon {
      width: 64px;
      height: 64px;
      margin: 0 auto 15px;
      background: linear-gradient(135deg, var(--uniba-primary), var(--uniba-blue-light));
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.8rem;
      color: white;
      box-shadow: 0 8px 20px rgba(26, 58, 92, 0.25);
    }
    
    .form-header h1 {
      font-family: 'Poppins', sans-serif;
      color: var(--uniba-primary);
      font-size: 1.6rem;
      font-weight: 700;
      letter-spacing: -0.5px;
      margin-bottom: 6px;
    }
    
    .form-header p {
      color: var(--text-muted);
      font-size: 0.9rem;
    }
    
    /* ========== FORM GRID ========== */
    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    
    .form-group {
      display: flex;
      flex-direction: column;
    }
    
    .form-group.full-width {
      grid-column: span 2;
    }
    
    .form-group label {
      font-weight: 600;
      color: var(--text-dark);
      font-size: 0.85rem;
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    
    .required { 
      color: var(--danger); 
      font-weight: 700;
    }
    
    .form-group input,
    .form-group textarea {
      width: 100%;
      padding: 12px 16px;
      border: 2px solid var(--border);
      border-radius: 10px;
      font-size: 0.95rem;
      font-family: 'Inter', sans-serif;
      transition: all 0.3s ease;
      background: #f8fafc;
      color: var(--text-dark);
    }
    
    .form-group input:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: var(--uniba-primary);
      background: #fff;
      box-shadow: 0 0 0 4px rgba(26, 58, 92, 0.1);
    }
    
    .form-group textarea { 
      resize: vertical; 
      min-height: 100px; 
    }
    
    /* ========== ACTIONS ========== */
    .form-actions {
      margin-top: 35px;
      display: flex;
      gap: 15px;
      justify-content: flex-end;
      align-items: center;
      flex-wrap: wrap;
    }
    
    .btn {
      padding: 12px 28px;
      border-radius: 10px;
      font-weight: 600;
      font-size: 0.95rem;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
      transition: all 0.3s;
      border: none;
      font-family: 'Inter', sans-serif;
    }
    
    .btn-primary {
      background: linear-gradient(135deg, var(--uniba-primary), var(--uniba-blue-light));
      color: white;
      box-shadow: 0 4px 12px rgba(26, 58, 92, 0.2);
    }
    
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(26, 58, 92, 0.35);
    }
    
    .btn-secondary {
      background: white;
      color: var(--text-muted);
      border: 2px solid var(--border);
    }
    
    .btn-secondary:hover {
      border-color: var(--uniba-primary);
      color: var(--uniba-primary);
      background: #f8fafc;
    }
    
    /* ========== INFO BOX ========== */
    .info-box {
      margin-top: 30px;
      padding: 16px 20px;
      background: linear-gradient(90deg, rgba(245, 158, 11, 0.1), rgba(245, 158, 11, 0.02));
      border-left: 4px solid var(--warning);
      border-radius: 10px;
      font-size: 0.85rem;
      color: #92400e;
      display: flex;
      align-items: flex-start;
      gap: 12px;
    }
    
    .info-box strong { color: #78350f; }
    
    /* ========== RESPONSIVE ========== */
    @media (max-width: 768px) {
      .main-wrapper { 
        margin-left: 0;
        padding: 20px;
      }
      .main-wrapper.expanded { 
        margin-left: 0;
      }
    }
    
    @media (max-width: 640px) {
      .form-container { padding: 25px 20px; }
      .form-grid { grid-template-columns: 1fr; }
      .form-group.full-width { grid-column: span 1; }
      .form-actions { flex-direction: column-reverse; width: 100%; }
      .btn { width: 100%; justify-content: center; }
      .form-header h1 { font-size: 1.3rem; }
    }
    
    /* ========== SCROLLBAR ========== */
    ::-webkit-scrollbar { 
      width: 10px;
      height: 10px;
    }
    
    ::-webkit-scrollbar-track { 
      background: #f1f5f9;
      border-radius: 5px;
    }
    
    ::-webkit-scrollbar-thumb { 
      background: linear-gradient(135deg, var(--uniba-primary), var(--uniba-blue-light));
      border-radius: 5px;
    }
    
    ::-webkit-scrollbar-thumb:hover { 
      background: var(--uniba-dark);
    }
  </style>
</head>
<body>
  <!-- Include Sidebar dari partials -->
  <%- include('partials/_sidebar') %>
  
  <!-- Main Wrapper -->
  <div class="main-wrapper">
    <div class="form-container">
      <!-- Header -->
      <div class="form-header">
        <div class="logo-icon">🤝</div>
        <h1><%= action === 'tambah' ? 'Tambah Mitra Baru' : 'Edit Data Mitra' %></h1>
        <p>SI Mitra DUDIKA — Universitas Islam Batik Surakarta</p>
      </div>
      
      <!-- Form -->
      <form method="POST" action="<%= action === 'tambah' ? '/mitra' : `/mitra/${mitra?.id}/update` %>">
        <div class="form-grid">
          
          <!-- Nama Instansi (Full Width) -->
          <div class="form-group full-width">
            <label for="nama_instansi">🏢 Nama Instansi / Perusahaan <span class="required">*</span></label>
            <input type="text" id="nama_instansi" name="nama_instansi" required value="<%= mitra?.nama_instansi || '' %>" placeholder="Contoh: PT. Maju Bersama">
          </div>

          <!-- Nama Kontak -->
          <div class="form-group">
            <label for="nama_kontak">👤 Nama Kontak Person</label>
            <input type="text" id="nama_kontak" name="nama_kontak" value="<%= mitra?.nama_kontak || '' %>" placeholder="Nama penanggung jawab">
          </div>

          <!-- Jabatan -->
          <div class="form-group">
            <label for="jabatan">💼 Jabatan</label>
            <input type="text" id="jabatan" name="jabatan" value="<%= mitra?.jabatan || '' %>" placeholder="Contoh: HRD Manager">
          </div>

          <!-- No HP -->
          <div class="form-group">
            <label for="no_hp_kontak">📱 Nomor HP Kontak <span class="required">*</span></label>
            <input type="tel" id="no_hp_kontak" name="no_hp_kontak" required value="<%= mitra?.no_hp_kontak || '' %>" placeholder="0812xxxxxxxx">
          </div>

          <!-- Email Fakultas -->
          <div class="form-group">
            <label for="email_fakultas">📧 Email Fakultas Bertanggung Jawab <span class="required">*</span></label>
            <input type="email" id="email_fakultas" name="email_fakultas" required value="<%= mitra?.email_fakultas || '' %>" placeholder="fti@uniba.ac.id">
          </div>

          <!-- Tanggal Mulai -->
          <div class="form-group">
            <label for="tanggal_mulai">📅 Tanggal Mulai Kerja Sama <span class="required">*</span></label>
            <input type="date" id="tanggal_mulai" name="tanggal_mulai" required value="<%= mitra?.tanggal_mulai || '' %>">
          </div>

          <!-- Tanggal Berakhir -->
          <div class="form-group">
            <label for="tanggal_berakhir">📅 Tanggal Berakhir Kerja Sama <span class="required">*</span></label>
            <input type="date" id="tanggal_berakhir" name="tanggal_berakhir" required value="<%= mitra?.tanggal_berakhir || '' %>">
          </div>

          <!-- Alamat (Full Width) -->
          <div class="form-group full-width">
            <label for="alamat">📍 Alamat Lengkap</label>
            <textarea id="alamat" name="alamat" rows="3" placeholder="Alamat lengkap instansi..."><%= mitra?.alamat || '' %></textarea>
          </div>
          
        </div>
        
        <!-- Actions -->
        <div class="form-actions">
          <a href="/mitra" class="btn btn-secondary">← Kembali ke Daftar</a>
          <button type="submit" class="btn btn-primary">💾 Simpan Data</button>
        </div>
      </form>
      
      <!-- Info Box -->
      <div class="info-box">
        <span style="font-size: 1.2rem;">💡</span>
        <div>
          <strong>Catatan Penting:</strong> 
          Upload dokumen legalitas (MoU, MoA, IA, PKS) dilakukan <strong>setelah</strong> data mitra berhasil disimpan, melalui halaman Detail Mitra.
        </div>
      </div>
    </div>
  </div>

  <script>
    // Logic untuk Toggle Sidebar dengan Chevron
    const sidebarToggle = document.getElementById('sidebarToggle');
    const sidebar = document.querySelector('.sidebar');
    const mainWrapper = document.querySelector('.main-wrapper');

    if (sidebarToggle && sidebar) {
      sidebarToggle.addEventListener('click', () => {
        if (window.innerWidth <= 768) {
          sidebar.classList.toggle('active');
          sidebarToggle.classList.toggle('shifted');
        } else {
          sidebar.classList.toggle('hidden');
          mainWrapper.classList.toggle('expanded');
          sidebarToggle.classList.toggle('shifted');
        }
      });

      window.addEventListener('resize', () => {
        if (window.innerWidth > 768) {
          sidebar.classList.remove('active');
        } else {
          sidebar.classList.remove('hidden');
          mainWrapper.classList.remove('expanded');
          sidebarToggle.classList.remove('shifted');
        }
      });
    }
    
    // Auto-focus ke field pertama saat halaman dimuat
    document.addEventListener('DOMContentLoaded', () => {
      const firstInput = document.querySelector('input[required]');
      if (firstInput) firstInput.focus();
    });
  </script>
</body>
</html>