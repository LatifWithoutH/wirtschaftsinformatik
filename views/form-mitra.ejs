<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= action === 'tambah' ? 'Tambah' : 'Edit' %> Mitra - SI Mitra DUDIKA | UNIBA</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --uniba-primary: #1a3a5c;
      --uniba-secondary: #8b6f47;
      --uniba-gold: #d4a017;
      --uniba-blue-light: #2c5282;
      --uniba-dark: #0f2439;
      
      --success: #10b981;
      --danger: #ef4444;
      --warning: #f59e0b;
      
      --text-dark: #1e293b;
      --text-muted: #64748b;
      --bg-light: #f8fafc;
      --border: #e2e8f0;
      
      --sidebar-width: 280px;
      --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.04);
      --shadow-md: 0 4px 20px rgba(0, 0, 0, 0.08);
      --shadow-lg: 0 10px 40px rgba(0, 0, 0, 0.12);
    }
    
    * { box-sizing: border-box; margin: 0; padding: 0; }
    
    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg-light);
      color: var(--text-dark);
      line-height: 1.6;
      min-height: 100vh;
      background-image: 
        radial-gradient(circle at 10% 20%, rgba(212, 160, 23, 0.03) 0%, transparent 40%),
        radial-gradient(circle at 90% 80%, rgba(26, 58, 92, 0.03) 0%, transparent 40%);
      overflow-x: hidden;
    }
    
    .main-wrapper {
      margin-left: var(--sidebar-width);
      transition: margin-left 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 40px 20px;
    }
    
    .main-wrapper.expanded { margin-left: 0; }
    
    .form-container {
      width: 100%;
      max-width: 800px;
      background: rgba(255, 255, 255, 0.97);
      padding: 40px;
      border-radius: 20px;
      box-shadow: var(--shadow-lg);
      border: 1px solid rgba(226, 232, 240, 0.6);
      backdrop-filter: blur(10px);
      animation: slideUp 0.5s ease;
    }
    
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    
    .form-header {
      text-align: center;
      margin-bottom: 35px;
      position: relative;
      padding-bottom: 20px;
      border-bottom: 2px solid #f1f5f9;
    }
    
    .form-header .logo-icon {
      width: 64px;
      height: 64px;
      margin: 0 auto 15px;
      background: linear-gradient(135deg, var(--uniba-primary), var(--uniba-blue-light));
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.8rem;
      color: white;
      box-shadow: 0 8px 20px rgba(26, 58, 92, 0.25);
    }
    
    .form-header h1 {
      font-family: 'Poppins', sans-serif;
      color: var(--uniba-primary);
      font-size: 1.6rem;
      font-weight: 700;
      letter-spacing: -0.5px;
      margin-bottom: 6px;
    }
    
    .form-header p { color: var(--text-muted); font-size: 0.9rem; }
    
    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    
    .form-group { display: flex; flex-direction: column; }
    .form-group.full-width { grid-column: span 2; }
    
    .form-group label {
      font-weight: 600;
      color: var(--text-dark);
      font-size: 0.85rem;
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    
    .required { color: var(--danger); font-weight: 700; }
    
    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      padding: 12px 16px;
      border: 2px solid var(--border);
      border-radius: 10px;
      font-size: 0.95rem;
      font-family: 'Inter', sans-serif;
      transition: all 0.3s ease;
      background: #f8fafc;
      color: var(--text-dark);
    }
    
    .form-group select {
      cursor: pointer;
      appearance: none;
      background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%2364748b' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
      background-repeat: no-repeat;
      background-position: right 12px center;
      background-size: 18px;
      padding-right: 40px;
    }
    
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: var(--uniba-primary);
      background: #fff;
      box-shadow: 0 0 0 4px rgba(26, 58, 92, 0.1);
    }
    
    .form-group textarea { resize: vertical; min-height: 100px; }
    
    /* Style untuk input/select readonly */
    .form-group input[readonly],
    .form-group select[disabled] {
      background: #f1f5f9;
      color: #64748b;
      cursor: not-allowed;
      opacity: 0.8;
      font-weight: 600;
      border-color: #e2e8f0;
    }
    
    .form-group input[readonly]:focus,
    .form-group select[disabled]:focus {
      border-color: #e2e8f0;
      box-shadow: none;
      background: #f1f5f9;
    }
    
    /* Info box untuk field yang di-lock */
    .field-lock-info {
      margin-top: 8px;
      padding: 10px 14px;
      background: linear-gradient(90deg, rgba(245, 158, 11, 0.12), rgba(245, 158, 11, 0.03));
      border-left: 3px solid var(--warning);
      border-radius: 8px;
      font-size: 0.8rem;
      color: #92400e;
      display: flex;
      align-items: flex-start;
      gap: 8px;
      line-height: 1.5;
    }
    
    .field-lock-info strong { color: #78350f; }
    
    /* Info text kecil di bawah field */
    .field-hint {
      margin-top: 6px;
      font-size: 0.75rem;
      color: var(--text-muted);
      display: block;
      line-height: 1.5;
    }
    
    .form-actions {
      margin-top: 35px;
      display: flex;
      gap: 15px;
      justify-content: flex-end;
      align-items: center;
      flex-wrap: wrap;
    }
    
    .btn {
      padding: 12px 28px;
      border-radius: 10px;
      font-weight: 600;
      font-size: 0.95rem;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
      transition: all 0.3s;
      border: none;
      font-family: 'Inter', sans-serif;
    }
    
    .btn-primary {
      background: linear-gradient(135deg, var(--uniba-primary), var(--uniba-blue-light));
      color: white;
      box-shadow: 0 4px 12px rgba(26, 58, 92, 0.2);
    }
    
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(26, 58, 92, 0.35);
    }
    
    .btn-secondary {
      background: white;
      color: var(--text-muted);
      border: 2px solid var(--border);
    }
    
    .btn-secondary:hover {
      border-color: var(--uniba-primary);
      color: var(--uniba-primary);
      background: #f8fafc;
    }
    
    .info-box {
      margin-top: 30px;
      padding: 16px 20px;
      background: linear-gradient(90deg, rgba(245, 158, 11, 0.1), rgba(245, 158, 11, 0.02));
      border-left: 4px solid var(--warning);
      border-radius: 10px;
      font-size: 0.85rem;
      color: #92400e;
      display: flex;
      align-items: flex-start;
      gap: 12px;
    }
    
    .info-box strong { color: #78350f; }
    
    @media (max-width: 768px) {
      .main-wrapper { margin-left: 0; padding: 20px; }
      .main-wrapper.expanded { margin-left: 0; }
    }
    
    @media (max-width: 640px) {
      .form-container { padding: 25px 20px; }
      .form-grid { grid-template-columns: 1fr; }
      .form-group.full-width { grid-column: span 1; }
      .form-actions { flex-direction: column-reverse; width: 100%; }
      .btn { width: 100%; justify-content: center; }
      .form-header h1 { font-size: 1.3rem; }
    }
    
    <!-- ::-webkit-scrollbar { width: 10px; height: 10px; } -->
    <!-- ::-webkit-scrollbar-track { background: #f1f5f9; border-radius: 5px; } -->
    <!-- ::-webkit-scrollbar-thumb { background: linear-gradient(135deg, var(--uniba-primary), var(--uniba-blue-light)); border-radius: 5px; } -->
    <!-- ::-webkit-scrollbar-thumb:hover { background: var(--uniba-dark); } -->
  </style>
</head>
<body>
  <%- include('partials/_sidebar') %>
  
  <%
    // ========================================================================
    // 🔒 LOGIKA: Siapa yang boleh edit fakultas & email?
    // - action === 'tambah' → hanya humas yang bisa akses (sudah di-lock di server.js)
    // - action === 'edit' + humas → boleh edit
    // - action === 'edit' + admin_fakultas → TIDAK BOLEH (readonly/disabled)
    // ========================================================================
    const canEditFakultasField = (action === 'tambah') || (user?.role === 'humas');
  %>
  
  <div class="main-wrapper">
    <div class="form-container">
      <div class="form-header">
        <div class="logo-icon">🤝</div>
        <h1><%= action === 'tambah' ? 'Tambah Mitra Baru' : 'Edit Data Mitra' %></h1>
        <p>SI Mitra DUDIKA — Universitas Islam Batik Surakarta</p>
      </div>
      
      <form method="POST" action="<%= action === 'tambah' ? '/mitra' : `/mitra/${mitra?.id}/update` %>">
        <div class="form-grid">
          
          <!-- Nama Instansi (Full Width) -->
          <div class="form-group full-width">
            <label for="nama_instansi">🏢 Nama Instansi / Perusahaan <span class="required">*</span></label>
            <input type="text" id="nama_instansi" name="nama_instansi" required value="<%= mitra?.nama_instansi || '' %>" placeholder="Contoh: PT. Maju Bersama">
          </div>

          <!-- ✨ FAKULTAS — DROPDOWN DINAMIS DARI DATABASE ✨ -->
          <div class="form-group">
            <label for="fakultas_id">
              🏛️ Fakultas Penanggung Jawab <span class="required">*</span>
            </label>
            
            <% if (canEditFakultasField) { %>
              <!-- ✅ HUMAS atau Form Tambah: boleh edit -->
              <select id="fakultas_id" name="fakultas_id" required>
                <option value="">-- Pilih Fakultas --</option>
                <% if (typeof fakultas !== 'undefined' && fakultas && fakultas.length > 0) { %>
                  <% fakultas.forEach(f => { %>
                    <option value="<%= f.id %>" <%= (mitra?.fakultas_id === f.id) ? 'selected' : '' %>>
                      <%= f.nama %> (<%= f.singkatan %>)
                    </option>
                  <% }); %>
                <% } else { %>
                  <option value="" disabled>⚠️ Data fakultas belum tersedia</option>
                <% } %>
              </select>
            <% } else { %>
              <!-- 🔒 ADMIN FAKULTAS: disabled + hidden field -->
              <% 
                const currentFakultas = (typeof fakultas !== 'undefined' && fakultas) 
                  ? fakultas.find(f => f.id === mitra?.fakultas_id) 
                  : null;
              %>
              <select disabled aria-label="Fakultas (tidak dapat diubah)">
                <option>
                  <%= currentFakultas 
                      ? `${currentFakultas.nama} (${currentFakultas.singkatan})` 
                      : 'Tidak ada fakultas' %>
                </option>
              </select>
              <input type="hidden" name="fakultas_id" value="<%= mitra?.fakultas_id || '' %>">
              
              <div class="field-lock-info">
                <span style="font-size:1rem">🔒</span>
                <div>
                  <strong>Hanya Humas yang dapat mengubah fakultas penanggung jawab.</strong><br>
                  Jika ada kesalahan data, silakan hubungi Humas untuk perbaikan.
                </div>
              </div>
            <% } %>
          </div>

          <!-- ✨ EMAIL PENANGGUNG JAWAB (FAKULTAS) — WAJIB ✨ -->
          <div class="form-group">
            <label for="email_fakultas">
              📧 Email Penanggung Jawab (Fakultas) <span class="required">*</span>
            </label>
            
            <% if (canEditFakultasField) { %>
              <!-- ✅ HUMAS atau Form Tambah: boleh edit -->
              <input type="email" 
                     id="email_fakultas" 
                     name="email_fakultas" 
                     required
                     value="<%= mitra?.email_fakultas || '' %>" 
                     placeholder="dekan.fti@uniba.ac.id"
                     style="text-transform: lowercase;">
              <small class="field-hint">
                💡 Email ini akan menerima notifikasi otomatis saat kerja sama akan berakhir
              </small>
            <% } else { %>
              <!-- 🔒 ADMIN FAKULTAS: readonly + hidden field -->
              <input type="email" 
                     id="email_fakultas_display" 
                     value="<%= mitra?.email_fakultas || '' %>" 
                     readonly 
                     placeholder="—"
                     aria-label="Email penanggung jawab (tidak dapat diubah)">
              <input type="hidden" name="email_fakultas" value="<%= mitra?.email_fakultas || '' %>">
              
              <div class="field-lock-info">
                <span style="font-size:1rem">🔒</span>
                <div>
                  <strong>Hanya Humas yang dapat mengubah email penanggung jawab.</strong><br>
                  Jika ada kesalahan data, silakan hubungi Humas untuk perbaikan.
                </div>
              </div>
            <% } %>
          </div>

          <!-- ✨ EMAIL RESMI MITRA — OPSIONAL ✨ -->
          <div class="form-group">
            <label for="email_mitra_asli">
              🏢 Email Resmi Mitra
            </label>
            
            <% if (canEditFakultasField) { %>
              <!-- ✅ HUMAS atau Form Tambah: boleh edit -->
              <input type="email" 
                     id="email_mitra_asli" 
                     name="email_mitra_asli" 
                     value="<%= mitra?.email_mitra_asli || '' %>" 
                     placeholder="info@pt-maju.com"
                     style="text-transform: lowercase;">
              <small class="field-hint">
                💡 Opsional — ditampilkan sebagai info kontak di notifikasi (tidak dikirimi email)
              </small>
            <% } else { %>
              <!-- 🔒 ADMIN FAKULTAS: readonly + hidden field -->
              <input type="email" 
                     id="email_mitra_asli_display" 
                     value="<%= mitra?.email_mitra_asli || '' %>" 
                     readonly 
                     placeholder="—"
                     aria-label="Email resmi mitra (tidak dapat diubah)">
              <input type="hidden" name="email_mitra_asli" value="<%= mitra?.email_mitra_asli || '' %>">
              
              <div class="field-lock-info">
                <span style="font-size:1rem">🔒</span>
                <div>
                  <strong>Hanya Humas yang dapat mengubah email resmi mitra.</strong><br>
                  Jika ada kesalahan data, silakan hubungi Humas untuk perbaikan.
                </div>
              </div>
            <% } %>
          </div>

          <!-- Nama Kontak -->
          <div class="form-group">
            <label for="nama_kontak">👤 Nama Kontak Person</label>
            <input type="text" id="nama_kontak" name="nama_kontak" value="<%= mitra?.nama_kontak || '' %>" placeholder="Nama penanggung jawab">
          </div>

          <!-- Jabatan -->
          <div class="form-group">
            <label for="jabatan">💼 Jabatan</label>
            <input type="text" id="jabatan" name="jabatan" value="<%= mitra?.jabatan || '' %>" placeholder="Contoh: HRD Manager">
          </div>

          <!-- Tanggal Mulai -->
          <div class="form-group">
            <label for="tanggal_mulai">📅 Tanggal Mulai Kerja Sama <span class="required">*</span></label>
            <input type="date" id="tanggal_mulai" name="tanggal_mulai" required value="<%= mitra?.tanggal_mulai || '' %>">
          </div>
		  
          <!-- No HP -->
          <div class="form-group">
            <label for="no_hp_kontak">📱 Nomor HP Kontak <span class="required">*</span></label>
            <input type="tel" id="no_hp_kontak" name="no_hp_kontak" required value="<%= mitra?.no_hp_kontak || '' %>" placeholder="0812xxxxxxxx">
          </div>

          <!-- Tanggal Berakhir -->
          <div class="form-group">
            <label for="tanggal_berakhir">📅 Tanggal Berakhir Kerja Sama <span class="required">*</span></label>
            <input type="date" id="tanggal_berakhir" name="tanggal_berakhir" required value="<%= mitra?.tanggal_berakhir || '' %>">
          </div>

          <!-- Alamat (Full Width) -->
          <div class="form-group full-width">
            <label for="alamat">📍 Alamat Lengkap</label>
            <textarea id="alamat" name="alamat" rows="3" placeholder="Alamat lengkap instansi..."><%= mitra?.alamat || '' %></textarea>
          </div>
          
        </div>
        
        <!-- Actions -->
        <div class="form-actions">
          <a href="/mitra" class="btn btn-secondary">← Kembali ke Daftar</a>
          <button type="submit" class="btn btn-primary">💾 Simpan Data</button>
        </div>
      </form>
      
      <!-- Info Box -->
      <div class="info-box">
        <span style="font-size: 1.2rem;">💡</span>
        <div>
          <strong>Catatan Penting:</strong> 
          <ul style="margin-top: 6px; padding-left: 20px; line-height: 1.8;">
            <li><strong>Fakultas Penanggung Jawab</strong> menentukan siapa yang bisa mengelola data mitra ini</li>
            <li><strong>Email Penanggung Jawab</strong> akan menerima notifikasi otomatis saat kerja sama akan berakhir</li>
            <li><strong>Email Resmi Mitra</strong> bersifat opsional, ditampilkan sebagai referensi kontak di notifikasi</li>
            <li>Upload dokumen legalitas (MoU, MoA, IA, PKS) dilakukan <strong>setelah</strong> data mitra berhasil disimpan, melalui halaman Detail Mitra</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

    <script>
    // ========== WRAP SEMUA DALAM DOMContentLoaded ==========
    document.addEventListener('DOMContentLoaded', function() {
      
   
        window.addEventListener('resize', () => {
          if (window.innerWidth > 768) {
            sidebar.classList.remove('active');
          } else {
            sidebar.classList.remove('hidden');
            if (mainWrapper) mainWrapper.classList.remove('expanded');
            sidebarToggle.classList.remove('shifted');
          }
        });
      }
    
      // ========== 2. GENERATE PASSWORD RANDOM ==========
      function generatePassword(length = 14) {
        const upper = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
        const lower = 'abcdefghijklmnopqrstuvwxyz';
        const numbers = '0123456789';
        const symbols = '!@#$%^&*';
        const allChars = upper + lower + numbers + symbols;
        let password = '';
        password += upper[Math.floor(Math.random() * upper.length)];
        password += lower[Math.floor(Math.random() * lower.length)];
        password += numbers[Math.floor(Math.random() * numbers.length)];
        password += symbols[Math.floor(Math.random() * symbols.length)];
        for (let i = password.length; i < length; i++) {
          password += allChars[Math.floor(Math.random() * allChars.length)];
        }
        return password.split('').sort(() => Math.random() - 0.5).join('');
      }
    
      // ========== 3. SET PASSWORD KE INPUT ==========
      function generateAndSetPassword() {
        const input = document.getElementById('passwordInput');
        if (!input) return;
        input.value = generatePassword(14);
        input.type = 'text';
        const eyeIcon = document.getElementById('eyeIcon');
        if (eyeIcon) eyeIcon.textContent = '🙈';
        updateStrengthMeter();
        showToast('✅ Password baru telah di-generate!', 'success');
      }
    
      // ========== 4. TOGGLE SHOW/HIDE PASSWORD ==========
      window.togglePasswordVisibility = function() {
        const input = document.getElementById('passwordInput');
        const icon = document.getElementById('eyeIcon');
        if (!input) return;
        if (input.type === 'password') {
          input.type = 'text';
          if (icon) icon.textContent = '🙈';
        } else {
          input.type = 'password';
          if (icon) icon.textContent = '👁️';
        }
      };
    
      // ========== 5. COPY PASSWORD ==========
      window.copyPassword = function() {
        const input = document.getElementById('passwordInput');
        if (!input || !input.value) {
          showToast('⚠️ Generate password terlebih dahulu!', '');
          return;
        }
        const originalType = input.type;
        input.type = 'text';
        input.select();
        try {
          navigator.clipboard.writeText(input.value).then(() => {
            showToast('📋 Password berhasil disalin ke clipboard!', 'success');
          }).catch(() => {
            document.execCommand('copy');
            showToast('📋 Password berhasil disalin!', 'success');
          });
        } catch (err) {
          showToast('❌ Gagal menyalin password', '');
        }
        input.type = originalType;
      };
    
      // ========== 6. PASSWORD STRENGTH METER ==========
      function updateStrengthMeter() {
        const passwordInput = document.getElementById('passwordInput');
        const fill = document.getElementById('strengthFill');
        const text = document.getElementById('strengthText');
        if (!passwordInput || !fill || !text) return;
        
        const password = passwordInput.value;
        if (!password) {
          fill.className = 'strength-fill';
          text.textContent = 'Kekuatan password akan muncul di sini';
          text.className = 'strength-text';
          return;
        }
        let score = 0;
        if (password.length >= 8) score++;
        if (password.length >= 12) score++;
        if (/[a-z]/.test(password) && /[A-Z]/.test(password)) score++;
        if (/\d/.test(password)) score++;
        if (/[^A-Za-z0-9]/.test(password)) score++;
        
        fill.className = 'strength-fill';
        text.className = 'strength-text';
        if (score <= 2) {
          fill.classList.add('weak');
          text.classList.add('weak');
          text.textContent = '⚠️ Lemah - Mudah ditebak';
        } else if (score === 3) {
          fill.classList.add('fair');
          text.classList.add('fair');
          text.textContent = '🟡 Cukup - Bisa lebih kuat';
        } else if (score === 4) {
          fill.classList.add('good');
          text.classList.add('good');
          text.textContent = '🔵 Bagus - Cukup aman';
        } else {
          fill.classList.add('strong');
          text.classList.add('strong');
          text.textContent = '🟢 Sangat Kuat - Excellent!';
        }
      }
    
      // ========== 7. TOAST NOTIFICATION ==========
      function showToast(message, type = '') {
        const toast = document.getElementById('toast');
        if (!toast) return;
        toast.textContent = message;
        toast.className = 'toast show ' + type;
        setTimeout(() => {
          toast.className = 'toast';
        }, 2500);
      }
    
      // ========== 8. TOGGLE FAKULTAS ==========
      window.toggleFakultas = function() {
        const role = document.getElementById('roleSelect');
        const fakultasGroup = document.getElementById('fakultasGroup');
        const fakultasInput = document.getElementById('fakultasSelect');
        if (!role || !fakultasGroup || !fakultasInput) return;
        
        if (role.value === 'admin_fakultas') {
          fakultasGroup.classList.remove('hidden');
          fakultasInput.setAttribute('required', 'required');
        } else {
          fakultasGroup.classList.add('hidden');
          fakultasInput.removeAttribute('required');
          fakultasInput.value = '';
        }
      };
    
      // ========== 9. VALIDASI FORM ==========
      const userForm = document.getElementById('userForm');
      if (userForm) {
        userForm.addEventListener('submit', function(e) {
          const password = document.getElementById('passwordInput');
          if (password && (!password.value || password.value.length < 8)) {
            e.preventDefault();
            showToast('⚠️ Password harus minimal 8 karakter!', '');
            return false;
          }
        });
      }
    
      // ========== 10. INIT: Generate password + focus ==========
      generateAndSetPassword();
      
      const nameInput = document.querySelector('input[name="name"]');
      if (nameInput) nameInput.focus();
    
      // ========== 11. Strength meter listener ==========
      const passwordInput = document.getElementById('passwordInput');
      if (passwordInput) {
        passwordInput.addEventListener('input', updateStrengthMeter);
      }
      
    }); // ===== AKHIR DOMContentLoaded =====
    </script>

</body>
</html>